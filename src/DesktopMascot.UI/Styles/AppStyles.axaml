<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Styles.Resources>
        <SolidColorBrush x:Key="Brush.Surface.Window" Color="#EEFFFFFF"/>
        <SolidColorBrush x:Key="Brush.Surface.Panel" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="Brush.Surface.Subtle" Color="#F9FAFB"/>
        <SolidColorBrush x:Key="Brush.Surface.Message" Color="#F2F4F7"/>
        <SolidColorBrush x:Key="Brush.Border.Subtle" Color="#EAECF0"/>
        <SolidColorBrush x:Key="Brush.Border.Strong" Color="#D0D5DD"/>
        <SolidColorBrush x:Key="Brush.Border.Glass" Color="#40FFFFFF"/>
        <SolidColorBrush x:Key="Brush.Text.Primary" Color="#101828"/>
        <SolidColorBrush x:Key="Brush.Text.Secondary" Color="#344054"/>
        <SolidColorBrush x:Key="Brush.Text.Muted" Color="#667085"/>
        <SolidColorBrush x:Key="Brush.Text.Body" Color="#475467"/>
        <SolidColorBrush x:Key="Brush.White" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="Brush.White.Subtle" Color="#DDFFFFFF"/>
        <SolidColorBrush x:Key="Brush.White.Action" Color="#22FFFFFF"/>
        <SolidColorBrush x:Key="Brush.White.Border" Color="#44FFFFFF"/>
        <SolidColorBrush x:Key="Brush.Info.Surface" Color="#EFF8FF"/>
        <SolidColorBrush x:Key="Brush.Info.Text" Color="#175CD3"/>
        <SolidColorBrush x:Key="Brush.Warning.Surface" Color="#FFFBEB"/>
        <SolidColorBrush x:Key="Brush.Warning.Border" Color="#FEDF89"/>
        <SolidColorBrush x:Key="Brush.Warning.Text" Color="#B54708"/>
        <SolidColorBrush x:Key="Brush.Success.Surface" Color="#F0FDF4"/>
        <SolidColorBrush x:Key="Brush.Success.Text" Color="#15803D"/>

        <CornerRadius x:Key="Radius.Window">18</CornerRadius>
        <CornerRadius x:Key="Radius.Panel">14</CornerRadius>
        <CornerRadius x:Key="Radius.Card">10</CornerRadius>
        <CornerRadius x:Key="Radius.Control">8</CornerRadius>
        <CornerRadius x:Key="Radius.Badge">9</CornerRadius>

        <Thickness x:Key="Space.WindowOuter">12</Thickness>
        <Thickness x:Key="Space.PanelPadding">14</Thickness>
        <Thickness x:Key="Space.CardPadding">12</Thickness>
        <Thickness x:Key="Space.InputPadding">10</Thickness>
    </Styles.Resources>

    <Style Selector="Border.floatingShell">
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Window}"/>
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Window}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Glass}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin" Value="{StaticResource Space.WindowOuter}"/>
        <Setter Property="BoxShadow" Value="0 12 28 0 #24000000"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="Border.chatShell">
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Panel}"/>
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Panel}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BoxShadow" Value="0 16 38 0 #28000000"/>
    </Style>

    <Style Selector="Border.toolCard">
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Subtle}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Card}"/>
        <Setter Property="Padding" Value="{StaticResource Space.CardPadding}"/>
    </Style>

    <Style Selector="Border.inlineCard">
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Panel}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Control}"/>
        <Setter Property="Padding" Value="10"/>
    </Style>

    <Style Selector="Border.characterDropZone">
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style Selector="Border.characterDropHint">
        <Setter Property="Background" Value="#DDF9FAFB"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="8,3"/>
    </Style>

    <Style Selector="Border.confirmationCard">
        <Setter Property="Background" Value="{StaticResource Brush.Warning.Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Warning.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Control}"/>
        <Setter Property="Padding" Value="10"/>
    </Style>

    <Style Selector="Border.windowTitleBar">
        <Setter Property="Background" Value="#08FFFFFF"/>
    </Style>

    <Style Selector="TextBlock.titleText">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="TextBlock.subtitleText">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}"/>
        <Setter Property="FontSize" Value="9"/>
    </Style>

    <Style Selector="TextBlock.panelTitle">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="TextBlock.sectionTitle">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="TextBlock.bodyText">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Body}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style Selector="TextBlock.captionText">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style Selector="Button.iconButton">
        <Setter Property="Width" Value="26"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}"/>
    </Style>

    <Style Selector="Button.headerAction">
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="Background" Value="{StaticResource Brush.White.Action}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.White.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.White}"/>
    </Style>

    <Style Selector="Button.primaryAction">
        <Setter Property="Foreground" Value="{StaticResource Brush.White}"/>
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Control}"/>
    </Style>

    <Style Selector="Button.secondaryAction">
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Control}"/>
        <Setter Property="Padding" Value="10,6"/>
    </Style>

    <Style Selector="Button.settingsNavButton">
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="12,9"/>
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Control}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
    </Style>

    <Style Selector="Button.mascotButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style Selector="TextBox.formInput">
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Control}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Strong}"/>
    </Style>

    <Style Selector="ProgressBar.compactProgress">
        <Setter Property="Minimum" Value="0"/>
        <Setter Property="Maximum" Value="100"/>
        <Setter Property="Height" Value="6"/>
    </Style>

    <Style Selector="Border.mascotIcon">
        <Setter Property="Width" Value="172"/>
        <Setter Property="Height" Value="232"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style Selector="Border.mascotHalo">
        <Setter Property="Width" Value="158"/>
        <Setter Property="Height" Value="158"/>
        <Setter Property="CornerRadius" Value="79"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BoxShadow" Value="0 0 0 0 #00000000"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style Selector="Border.mascotIcon.busy Border.mascotHalo">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BoxShadow" Value="0 0 0 0 #00000000"/>
    </Style>

    <Style Selector="Border.mascotIcon.waiting Border.mascotHalo">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BoxShadow" Value="0 0 0 0 #00000000"/>
    </Style>

    <Style Selector="Border.mascotIcon.error Border.mascotHalo">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BoxShadow" Value="0 0 0 0 #00000000"/>
    </Style>

    <Style Selector="Border.mascotIcon.completed Border.mascotHalo">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BoxShadow" Value="0 0 0 0 #00000000"/>
    </Style>

    <Style Selector="Border.mascotPortrait">
        <Setter Property="Width" Value="164"/>
        <Setter Property="Height" Value="224"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="BoxShadow" Value="0 0 0 0 #00000000"/>
        <Setter Property="ClipToBounds" Value="False"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.mascotStateChip">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="8,3"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="Margin" Value="0,0,0,2"/>
        <Setter Property="BoxShadow" Value="0 4 12 0 #33000000"/>
    </Style>

    <Style Selector="Border.chatDialog">
        <Setter Property="Width" Value="780"/>
        <Setter Property="Height" Value="640"/>
        <Setter Property="CornerRadius" Value="18"/>
        <Setter Property="Background" Value="#960B0D12"/>
        <Setter Property="BorderBrush" Value="#38FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BoxShadow" Value="0 18 42 0 #38000000"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="Border.dialogTitleBar">
        <Setter Property="Background" Value="#B811151F"/>
        <Setter Property="BorderBrush" Value="#16FFFFFF"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <Style Selector="TextBlock.dialogTitleText">
        <Setter Property="Foreground" Value="#F8FAFC"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="TextBlock.dialogSubtitleText">
        <Setter Property="Foreground" Value="#94A3B8"/>
        <Setter Property="FontSize" Value="10"/>
    </Style>

    <Style Selector="Button.dialogIconButton">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Background" Value="#10FFFFFF"/>
        <Setter Property="BorderBrush" Value="#18FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="#E5E7EB"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style Selector="Button.dialogIconButton:pointerover">
        <Setter Property="Background" Value="#20FFFFFF"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Border.sidebarPanel">
        <Setter Property="Background" Value="#920F1117"/>
        <Setter Property="BorderBrush" Value="#16FFFFFF"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
    </Style>

    <Style Selector="TextBlock.sidebarTitle">
        <Setter Property="Foreground" Value="#F8FAFC"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="TextBlock.sidebarEmptyText">
        <Setter Property="Foreground" Value="#64748B"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style Selector="TextBlock.sidebarFooterText">
        <Setter Property="Foreground" Value="#94A3B8"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style Selector="Border.historyItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Margin" Value="8,2"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style Selector="Border.historyItem:pointerover">
        <Setter Property="Background" Value="#14FFFFFF"/>
    </Style>

    <Style Selector="TextBlock.historyTitle">
        <Setter Property="Foreground" Value="#E5E7EB"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>

    <Style Selector="TextBlock.historyTime">
        <Setter Property="Foreground" Value="#64748B"/>
        <Setter Property="FontSize" Value="10"/>
    </Style>

    <Style Selector="TextBlock.historyPreview">
        <Setter Property="Foreground" Value="#94A3B8"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="LineHeight" Value="15"/>
    </Style>

    <Style Selector="Button.historyActionButton">
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="CornerRadius" Value="7"/>
        <Setter Property="Background" Value="#16FFFFFF"/>
        <Setter Property="BorderBrush" Value="#24FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="#E5E7EB"/>
        <Setter Property="FontSize" Value="10"/>
    </Style>

    <Style Selector="Button.historyDangerButton">
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="CornerRadius" Value="7"/>
        <Setter Property="Background" Value="#24DC2626"/>
        <Setter Property="BorderBrush" Value="#44F87171"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="#FCA5A5"/>
        <Setter Property="FontSize" Value="10"/>
    </Style>

    <Style Selector="Button.newChatButton">
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Background" Value="#18FFFFFF"/>
        <Setter Property="BorderBrush" Value="#20FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="#E5E7EB"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style Selector="Border.messageList">
        <Setter Property="Background" Value="#760B0D12"/>
    </Style>

    <Style Selector="Border.screenSelectionContextCard">
        <Setter Property="Background" Value="#1A2563EB"/>
        <Setter Property="BorderBrush" Value="#4A60A5FA"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="12"/>
    </Style>

    <Style Selector="Border.screenContextBadge">
        <Setter Property="Background" Value="#243B82F6"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="8,3"/>
    </Style>

    <Style Selector="TextBlock.screenContextTitle">
        <Setter Property="Foreground" Value="#EAF2FF"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="TextBlock.screenContextBody">
        <Setter Property="Foreground" Value="#CBD5E1"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style Selector="TextBlock.screenContextMeta">
        <Setter Property="Foreground" Value="#93C5FD"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="TextBlock.screenContextBadgeText">
        <Setter Property="Foreground" Value="#BFDBFE"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="Expander.screenContextDetailsExpander">
        <Setter Property="Foreground" Value="#BFDBFE"/>
    </Style>

    <Style Selector="Border.screenContextDetailRow">
        <Setter Property="Background" Value="#142563EB"/>
        <Setter Property="BorderBrush" Value="#243B82F6"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="7"/>
        <Setter Property="Padding" Value="8,6"/>
    </Style>

    <Style Selector="TextBlock.screenContextDetailLabel">
        <Setter Property="Foreground" Value="#93C5FD"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="TextBlock.screenContextDetailValue">
        <Setter Property="Foreground" Value="#E2E8F0"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style Selector="Border.screenContextScreenshotRow">
        <Setter Property="Background" Value="#1D0F172A"/>
        <Setter Property="BorderBrush" Value="#3A93C5FD"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="8,6"/>
    </Style>

    <Style Selector="Button.screenContextEvidenceButton">
        <Setter Property="Background" Value="#243B82F6"/>
        <Setter Property="BorderBrush" Value="#5093C5FD"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="7"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Foreground" Value="#EFF6FF"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="Button.screenContextEvidenceButton:pointerover">
        <Setter Property="Background" Value="#334F9BFF"/>
        <Setter Property="BorderBrush" Value="#8093C5FD"/>
    </Style>

    <Style Selector="Button.screenContextActionButton">
        <Setter Property="Background" Value="#263B82F6"/>
        <Setter Property="BorderBrush" Value="#4A93C5FD"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="9,5"/>
        <Setter Property="MinHeight" Value="34"/>
    </Style>

    <Style Selector="Button.screenContextActionButton:pointerover">
        <Setter Property="Background" Value="#334F9BFF"/>
        <Setter Property="BorderBrush" Value="#8093C5FD"/>
    </Style>

    <Style Selector="TextBlock.screenContextActionTitle">
        <Setter Property="Foreground" Value="#EFF6FF"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="TextBlock.screenContextActionMeta">
        <Setter Property="Foreground" Value="#93C5FD"/>
        <Setter Property="FontSize" Value="9"/>
    </Style>

    <Style Selector="TextBlock.emptyChatTitle">
        <Setter Property="Foreground" Value="#F8FAFC"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="TextBlock.emptyChatHint">
        <Setter Property="Foreground" Value="#94A3B8"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style Selector="Border.messageBubble">
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="MaxWidth" Value="500"/>
        <Setter Property="BoxShadow" Value="0 8 18 0 #22000000"/>
    </Style>

    <Style Selector="TextBlock.messageRole">
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <Style Selector="TextBlock.messageContent">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="LineHeight" Value="20"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style Selector="Button.bubbleAudioButton">
        <Setter Property="Padding" Value="9,4"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Background" Value="#140F172A"/>
        <Setter Property="BorderBrush" Value="#1F0F172A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="#334155"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style Selector="Border.statusBar">
        <Setter Property="Background" Value="#A811151F"/>
        <Setter Property="BorderBrush" Value="#16FFFFFF"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>

    <Style Selector="TextBlock.statusPercentText">
        <Setter Property="Foreground" Value="#94A3B8"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style Selector="Border.inputArea">
        <Setter Property="Background" Value="#B011151F"/>
        <Setter Property="BorderBrush" Value="#16FFFFFF"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>

    <Style Selector="TextBox.chatInput">
        <Setter Property="CornerRadius" Value="13"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#22FFFFFF"/>
        <Setter Property="Background" Value="#F8FAFC"/>
        <Setter Property="Foreground" Value="#0F172A"/>
        <Setter Property="Padding" Value="13,10"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <Style Selector="Button.sendButton">
        <Setter Property="Background" Value="#2563EB"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="CornerRadius" Value="13"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="Button.sendButton:pointerover">
        <Setter Property="Background" Value="#1D4ED8"/>
    </Style>

    <Style Selector="Button.voiceButton">
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="CornerRadius" Value="13"/>
        <Setter Property="Background" Value="#18FFFFFF"/>
        <Setter Property="BorderBrush" Value="#24FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="#E5E7EB"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style Selector="TextBlock.voiceStatusText">
        <Setter Property="Foreground" Value="#94A3B8"/>
        <Setter Property="FontSize" Value="10"/>
    </Style>

    <Style Selector="Border.inlineSettingsHeader">
        <Setter Property="Background" Value="#8E11151F"/>
        <Setter Property="BorderBrush" Value="#16FFFFFF"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <Style Selector="TextBlock.inlineSettingsTitle">
        <Setter Property="Foreground" Value="#F8FAFC"/>
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="TextBlock.inlineSettingsSubtitle">
        <Setter Property="Foreground" Value="#A7B2C3"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="LineHeight" Value="17"/>
    </Style>

    <Style Selector="Button.inlineSettingsBackButton">
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="CornerRadius" Value="9"/>
        <Setter Property="Background" Value="#18FFFFFF"/>
        <Setter Property="BorderBrush" Value="#24FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="#F8FAFC"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style Selector="Border.inlineSettingsNav">
        <Setter Property="Background" Value="#780F1117"/>
        <Setter Property="BorderBrush" Value="#16FFFFFF"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
    </Style>

    <Style Selector="Button.inlineSettingsNavButton">
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="11,8"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="#CBD5E1"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style Selector="Button.inlineSettingsNavButton:pointerover">
        <Setter Property="Background" Value="#16FFFFFF"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style Selector="Border.inlineSettingsCard">
        <Setter Property="Background" Value="#18FFFFFF"/>
        <Setter Property="BorderBrush" Value="#22FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="14"/>
    </Style>

    <Style Selector="Border.inlineSettingsInnerCard">
        <Setter Property="Background" Value="#0FFFFFFF"/>
        <Setter Property="BorderBrush" Value="#18FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="9"/>
        <Setter Property="Padding" Value="10"/>
    </Style>

    <Style Selector="Border.inlineSettingsBusyOverlay">
        <Setter Property="Background" Value="#9A05070B"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="ZIndex" Value="10"/>
    </Style>

    <Style Selector="Border.dataDirectoryRow">
