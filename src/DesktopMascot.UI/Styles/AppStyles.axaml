<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Styles.Resources>
        <SolidColorBrush x:Key="Brush.Surface.Window" Color="#EEFFFFFF"/>
        <SolidColorBrush x:Key="Brush.Surface.Panel" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="Brush.Surface.Subtle" Color="#F9FAFB"/>
        <SolidColorBrush x:Key="Brush.Surface.Message" Color="#F2F4F7"/>
        <SolidColorBrush x:Key="Brush.Border.Subtle" Color="#EAECF0"/>
        <SolidColorBrush x:Key="Brush.Border.Strong" Color="#D0D5DD"/>
        <SolidColorBrush x:Key="Brush.Border.Glass" Color="#40FFFFFF"/>
        <SolidColorBrush x:Key="Brush.Text.Primary" Color="#101828"/>
        <SolidColorBrush x:Key="Brush.Text.Secondary" Color="#344054"/>
        <SolidColorBrush x:Key="Brush.Text.Muted" Color="#667085"/>
        <SolidColorBrush x:Key="Brush.Text.Body" Color="#475467"/>
        <SolidColorBrush x:Key="Brush.White" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="Brush.White.Subtle" Color="#DDFFFFFF"/>
        <SolidColorBrush x:Key="Brush.White.Action" Color="#22FFFFFF"/>
        <SolidColorBrush x:Key="Brush.White.Border" Color="#44FFFFFF"/>
        <SolidColorBrush x:Key="Brush.Info.Surface" Color="#EFF8FF"/>
        <SolidColorBrush x:Key="Brush.Info.Text" Color="#175CD3"/>
        <SolidColorBrush x:Key="Brush.Warning.Surface" Color="#FFFBEB"/>
        <SolidColorBrush x:Key="Brush.Warning.Border" Color="#FEDF89"/>
        <SolidColorBrush x:Key="Brush.Warning.Text" Color="#B54708"/>
        <SolidColorBrush x:Key="Brush.Success.Surface" Color="#F0FDF4"/>
        <SolidColorBrush x:Key="Brush.Success.Text" Color="#15803D"/>

        <CornerRadius x:Key="Radius.Window">18</CornerRadius>
        <CornerRadius x:Key="Radius.Panel">14</CornerRadius>
        <CornerRadius x:Key="Radius.Card">10</CornerRadius>
        <CornerRadius x:Key="Radius.Control">8</CornerRadius>
        <CornerRadius x:Key="Radius.Badge">9</CornerRadius>

        <Thickness x:Key="Space.WindowOuter">12</Thickness>
        <Thickness x:Key="Space.PanelPadding">14</Thickness>
        <Thickness x:Key="Space.CardPadding">12</Thickness>
        <Thickness x:Key="Space.InputPadding">10</Thickness>
    </Styles.Resources>

    <Style Selector="Border.floatingShell">
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Window}"/>
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Window}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Glass}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin" Value="{StaticResource Space.WindowOuter}"/>
        <Setter Property="BoxShadow" Value="0 12 28 0 #24000000"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <Style Selector="Border.chatShell">
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Panel}"/>
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Panel}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BoxShadow" Value="0 16 38 0 #28000000"/>
    </Style>

    <Style Selector="Border.toolCard">
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Subtle}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Card}"/>
        <Setter Property="Padding" Value="{StaticResource Space.CardPadding}"/>
    </Style>

    <Style Selector="Border.inlineCard">
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Panel}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Control}"/>
        <Setter Property="Padding" Value="10"/>
    </Style>

    <Style Selector="Border.confirmationCard">
        <Setter Property="Background" Value="{StaticResource Brush.Warning.Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Warning.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Control}"/>
        <Setter Property="Padding" Value="10"/>
    </Style>

    <Style Selector="Border.windowTitleBar">
        <Setter Property="Background" Value="#08FFFFFF"/>
    </Style>

    <Style Selector="TextBlock.titleText">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="TextBlock.subtitleText">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}"/>
        <Setter Property="FontSize" Value="9"/>
    </Style>

    <Style Selector="TextBlock.panelTitle">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="TextBlock.sectionTitle">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style Selector="TextBlock.bodyText">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Body}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style Selector="TextBlock.captionText">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <Style Selector="Button.iconButton">
        <Setter Property="Width" Value="26"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}"/>
    </Style>

    <Style Selector="Button.headerAction">
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="Background" Value="{StaticResource Brush.White.Action}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.White.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.White}"/>
    </Style>

    <Style Selector="Button.primaryAction">
        <Setter Property="Foreground" Value="{StaticResource Brush.White}"/>
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Control}"/>
    </Style>

    <Style Selector="Button.secondaryAction">
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Control}"/>
        <Setter Property="Padding" Value="10,6"/>
    </Style>

    <Style Selector="Button.settingsNavButton">
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="12,9"/>
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Control}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
    </Style>

    <Style Selector="Button.mascotButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style Selector="TextBox.formInput">
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Control}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Strong}"/>
    </Style>

    <Style Selector="ProgressBar.compactProgress">
        <Setter Property="Minimum" Value="0"/>
        <Setter Property="Maximum" Value="100"/>
        <Setter Property="Height" Value="6"/>
    </Style>

    <!-- 角色图标样式 -->
    <Style Selector="Border.mascotIcon">
        <Setter Property="Width" Value="80"/>
        <Setter Property="Height" Value="80"/>
        <Setter Property="CornerRadius" Value="40"/>
        <Setter Property="Background" Value="#EEFFFFFF"/>
        <Setter Property="BorderBrush" Value="#40FFFFFF"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BoxShadow" Value="0 4 12 0 #24000000"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="Margin" Value="12,0,0,12"/>
    </Style>

    <!-- 对话框样式 -->
    <Style Selector="Border.chatDialog">
        <Setter Property="Width" Value="320"/>
        <Setter Property="Height" Value="480"/>
        <Setter Property="CornerRadius" Value="18"/>
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Window}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Glass}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BoxShadow" Value="0 12 28 0 #24000000"/>
        <Setter Property="ClipToBounds" Value="True"/>
    </Style>

    <!-- 对话框标题栏 -->
    <Style Selector="Border.dialogTitleBar">
        <Setter Property="Background" Value="#08FFFFFF"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <!-- 对话框标题文字 -->
    <Style Selector="TextBlock.dialogTitleText">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- 侧边栏样式 -->
    <Style Selector="Border.sidebarPanel">
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Subtle}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
    </Style>

    <!-- 侧边栏标题 -->
    <Style Selector="TextBlock.sidebarTitle">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- 历史项 -->
    <Style Selector="Border.historyItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Margin" Value="8,2"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style Selector="Border.historyItem:pointerover">
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Panel}"/>
    </Style>

    <!-- 历史标题 -->
    <Style Selector="TextBlock.historyTitle">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>

    <!-- 历史时间 -->
    <Style Selector="TextBlock.historyTime">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}"/>
        <Setter Property="FontSize" Value="10"/>
    </Style>

    <!-- 新建对话按钮 -->
    <Style Selector="Button.newChatButton">
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Panel}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- 消息气泡 -->
    <Style Selector="Border.messageBubble">
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="MaxWidth" Value="280"/>
    </Style>

    <!-- 消息角色 -->
    <Style Selector="TextBlock.messageRole">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,0,2"/>
    </Style>

    <!-- 消息内容 -->
    <Style Selector="TextBlock.messageContent">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Body}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- 状态条 -->
    <Style Selector="Border.statusBar">
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Subtle}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>

    <!-- 输入区 -->
    <Style Selector="Border.inputArea">
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Panel}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>

    <!-- 聊天输入框 -->
    <Style Selector="TextBox.chatInput">
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Strong}"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- 发送按钮 -->
    <Style Selector="Button.sendButton">
        <Setter Property="Background" Value="{StaticResource Brush.Info.Text}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
</Styles>
