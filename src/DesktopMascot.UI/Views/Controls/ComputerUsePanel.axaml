<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DesktopMascot.UI.ViewModels"
             x:Class="DesktopMascot.UI.Views.Controls.ComputerUsePanel"
             x:DataType="vm:FloatingWindowViewModel">
    <Border Classes="computerUsePanel">
        <Grid ColumnDefinitions="210,*"
              ColumnSpacing="12">
            <Border Classes="computerUsePreview">
                <Grid>
                    <Image Source="{Binding ComputerUseScreenshotImage}"
                           Stretch="UniformToFill"
                           IsVisible="{Binding HasComputerUseScreenshot}"/>
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Width="150"
                                Spacing="6"
                                IsVisible="{Binding HasNoComputerUseScreenshot}">
                        <TextBlock Text="屏幕目标"
                                   Classes="computerUseSubTitle"
                                   TextAlignment="Center"/>
                        <TextBlock Text="{Binding ComputerUseScreenshotStatus}"
                                   Classes="computerUseCaption"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <Border Classes="computerUsePreviewBadge"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Left">
                        <TextBlock Text="{Binding ComputerUseTargetText}"
                                   Classes="computerUseCaption"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1"
                        Spacing="9">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="2">
                    <TextBlock Text="Computer Use"
                               Classes="computerUseTitle"/>
                    <TextBlock Text="{Binding ComputerUseStatusText}"
                               Classes="computerUseBody"
                               TextWrapping="Wrap"
                               MaxLines="2"/>
                </StackPanel>
                <Border Grid.Column="1"
                        Classes="computerUseModeBadge"
                        VerticalAlignment="Top">
                    <TextBlock Text="{Binding ComputerUseModeText}"
                               Classes="computerUseModeText"/>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="2">
                    <TextBlock Text="目标"
                               Classes="computerUseSubTitle"/>
                    <TextBlock Text="{Binding ComputerUseTargetText}"
                               Classes="computerUseBody"
                               TextWrapping="Wrap"
                               MaxLines="2"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="5"
                            VerticalAlignment="Center">
                    <Button Content="暂停"
                            Classes="computerUseButton"
                            Command="{Binding PauseComputerUseCommand}"/>
                    <Button Content="继续"
                            Classes="computerUseButton"
                            Command="{Binding ResumeComputerUseCommand}"/>
                    <Button Content="接管"
                            Classes="computerUsePrimaryButton"
                            Command="{Binding TakeOverComputerUseCommand}"
                            Padding="10,5"/>
                    <Button Content="权限"
                            Classes="computerUseButton"
                            Command="{Binding OpenComputerUsePermissionCommand}"/>
                    <Button Content="停止"
                            Classes="computerUseDangerButton"
                            Command="{Binding StopComputerUseCommand}"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="{Binding ComputerUseControlStatus}"
                       Classes="computerUseCaption"
                       TextWrapping="Wrap"/>

            <TextBlock Text="暂无 Computer Use 动作"
                       Classes="computerUseCaption"
                       IsVisible="{Binding HasNoComputerUseActions}"/>

            <ScrollViewer MaxHeight="138"
                          VerticalScrollBarVisibility="Auto"
                          IsVisible="{Binding HasComputerUseActions}">
                <ItemsControl ItemsSource="{Binding ComputerUseActions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ComputerUseActionItem">
                            <Border Classes="computerUseActionRow"
                                    Classes.current="{Binding IsCurrent}"
                                    Margin="0,0,0,7">
                                <Grid ColumnDefinitions="*,Auto"
                                      RowDefinitions="Auto,Auto,Auto"
                                      ColumnSpacing="8">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="6">
                                        <TextBlock Text="{Binding ActionName}"
                                                   Classes="computerUseActionTitle"/>
                                        <Border Background="{Binding StatusBrush}"
                                                CornerRadius="8"
                                                Padding="6,1">
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{Binding StatusForeground}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding TimeText}"
                                               Classes="computerUseCaption"/>
                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="2"
                                               Text="{Binding Target}"
                                               Classes="computerUseCaption"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,3,0,0"/>
                                    <TextBlock Grid.Row="2"
                                               Grid.ColumnSpan="2"
                                               Text="{Binding Detail}"
                                               Classes="computerUseBody"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0"
                                               MaxLines="2"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Grid ColumnDefinitions="*,Auto"
                  Margin="0,2,0,0">
                <TextBlock Text="操作日志"
                           Classes="computerUseSubTitle"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding ComputerUseControlStatus}"
                           Classes="computerUseCaption"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="260"/>
            </Grid>

            <TextBlock Text="暂无操作日志"
                       Classes="computerUseCaption"
                       IsVisible="{Binding HasNoComputerUseLogItems}"/>

            <ScrollViewer MaxHeight="112"
                          VerticalScrollBarVisibility="Auto"
                          IsVisible="{Binding HasComputerUseLogItems}">
                <ItemsControl ItemsSource="{Binding ComputerUseLogItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ComputerUseLogItem">
                            <Grid ColumnDefinitions="18,*"
                                  RowDefinitions="Auto,Auto"
                                  Margin="0,0,0,8">
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="{Binding DotBrush}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Top"
                                         Margin="0,4,0,0"/>
                                <Border Grid.Column="1"
                                        Grid.RowSpan="2"
                                        Classes="computerUseLogRow">
                                    <Grid ColumnDefinitions="*,Auto"
                                          RowDefinitions="Auto,Auto"
                                          ColumnSpacing="8">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="6">
                                            <TextBlock Text="{Binding Title}"
                                                       Classes="computerUseActionTitle"/>
                                            <TextBlock Text="{Binding StatusText}"
                                                       Classes="computerUseCaption"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding TimeText}"
                                                   Classes="computerUseCaption"/>
                                        <TextBlock Grid.Row="1"
                                                   Grid.ColumnSpan="2"
                                                   Text="{Binding Detail}"
                                                   Classes="computerUseBody"
                                                   TextWrapping="Wrap"
                                                   MaxLines="2"
                                                   Margin="0,3,0,0"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
