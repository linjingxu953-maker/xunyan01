<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DesktopMascot.UI.ViewModels"
             x:Class="DesktopMascot.UI.Views.Controls.StatusBadge"
             x:DataType="vm:FloatingWindowViewModel">
    <Border Background="{Binding StateAccentBrush}"
            CornerRadius="{StaticResource Radius.Badge}"
            Padding="8,3"
            VerticalAlignment="Top">
        <TextBlock Text="{Binding CurrentStateText}"
                   Foreground="{StaticResource Brush.White}"
                   FontSize="11"
                   FontWeight="SemiBold"/>
    </Border>
</UserControl>
