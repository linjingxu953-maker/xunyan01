<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DesktopMascot.UI.ViewModels"
             xmlns:controls="using:DesktopMascot.UI.Views.Controls"
             x:Class="DesktopMascot.UI.Views.Controls.TaskDetailPanel"
             x:DataType="vm:FloatingWindowViewModel">
    <Border Classes="toolCard">
        <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="{Binding ActiveTaskTitle}"
                               Classes="panelTitle"/>
                    <TextBlock Text="{Binding ActiveTaskTypeText}"
                               Classes="captionText"/>
                </StackPanel>
                <controls:StatusBadge Grid.Column="1"/>
            </Grid>
            <TextBlock Text="{Binding TaskSummary}"
                       Classes="bodyText"
                       MaxLines="3"/>

            <Border Classes="screenSelectionContextCard"
                    IsVisible="{Binding HasScreenSelectionContext}">
                <Grid ColumnDefinitions="*,Auto"
                      RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                    <StackPanel Grid.Row="0"
                                Grid.Column="0"
                                Spacing="3">
                        <TextBlock Text="{Binding ScreenSelectionContext.Title}"
                                   Classes="screenContextTitle"/>
                        <TextBlock Text="{Binding ScreenSelectionContext.DetailText}"
                                   Classes="screenContextBody"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <Border Grid.Row="0"
                            Grid.Column="1"
                            Classes="screenContextBadge"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding ScreenSelectionContext.StatusText}"
                                   Classes="screenContextBadgeText"/>
                    </Border>
                    <Grid Grid.Row="1"
                          Grid.ColumnSpan="2"
                          ColumnDefinitions="*,Auto"
                          Margin="0,10,0,0">
                        <TextBlock Text="{Binding ScreenSelectionContext.RegionText}"
                                   Classes="screenContextMeta"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ScreenSelectionContext.SizeText}"
                                   Classes="screenContextMeta"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                    <Border Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Classes="screenContextScreenshotRow"
                            IsVisible="{Binding ScreenSelectionContext.HasScreenshotEvidence}"
                            ToolTip.Tip="{Binding ScreenSelectionContext.ScreenshotPath}"
                            Margin="0,10,0,0">
                        <Grid ColumnDefinitions="Auto,*,Auto"
                              RowDefinitions="Auto,Auto"
                              ColumnSpacing="10"
                              RowSpacing="8">
                            <Border Classes="screenContextPreviewFrame"
                                    IsVisible="{Binding ScreenSelectionContext.HasScreenshotPreview}">
                                <Image Source="{Binding ScreenSelectionContext.ScreenshotPath, Converter={StaticResource ScreenshotPreviewConverter}}"
                                       Width="96"
                                       Height="58"
                                       Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Spacing="2"
                                        VerticalAlignment="Center">
                                <TextBlock Text="截图证据"
                                           Classes="screenContextDetailLabel"/>
                                <TextBlock Text="{Binding ScreenSelectionContext.ScreenshotFileName}"
                                           Classes="screenContextDetailValue"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        Spacing="6"
                                        VerticalAlignment="Center">
                                <Button Classes="screenContextEvidenceButton"
                                        Content="{Binding ScreenScreenshotPreview.ToggleText}"
                                        IsEnabled="{Binding ScreenScreenshotPreview.CanTogglePreview}"
                                        Click="ToggleScreenScreenshotPreview_Click"/>
                                <Button Classes="screenContextEvidenceButton"
                                        IsEnabled="{Binding ScreenScreenshotPreview.CanCopyPath}"
                                        Click="CopyScreenScreenshotPath_Click">
                                    复制路径
                                </Button>
                                <Button Classes="screenContextEvidenceButton"
                                        Click="UseScreenScreenshotEvidence_Click">
                                    引用截图
                                </Button>
                            </StackPanel>
                            <Border Grid.Row="1"
                                    Grid.ColumnSpan="3"
                                    Classes="screenContextExpandedPreviewFrame"
                                    IsVisible="{Binding ScreenScreenshotPreview.ShowExpandedPreview}">
                                <Image Source="{Binding ScreenSelectionContext.ScreenshotPath, Converter={StaticResource ScreenshotPreviewConverter}}"
                                       MaxHeight="200"
                                       Stretch="Uniform"/>
                            </Border>
                        </Grid>
                    </Border>
                    <Expander Grid.Row="3"
                              Grid.ColumnSpan="2"
                              Classes="screenContextDetailsExpander"
                              IsVisible="{Binding ScreenSelectionContext.HasDetailItems}"
                              Margin="0,10,0,0">
                        <Expander.Header>
                            <TextBlock Text="查看识别详情"
                                       Classes="screenContextMeta"/>
                        </Expander.Header>
                        <ItemsControl ItemsSource="{Binding ScreenSelectionContext.DetailItems}"
                                      Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ScreenContextDetailItem">
                                    <Border Classes="screenContextDetailRow"
                                            Margin="0,0,0,6">
                                        <Grid ColumnDefinitions="74,*"
                                              ColumnSpacing="8">
                                            <TextBlock Text="{Binding Label}"
                                                       Classes="screenContextDetailLabel"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Value}"
                                                       Classes="screenContextDetailValue"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>
                    <ItemsControl Grid.Row="4"
                                  Grid.ColumnSpan="2"
                                  ItemsSource="{Binding ScreenSelectionContext.SuggestedActions}"
                                  IsVisible="{Binding ScreenSelectionContext.HasSuggestedActions}"
                                  Margin="0,10,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ScreenContextActionItem">
                                <Button Classes="screenContextActionButton"
                                        Tag="{Binding}"
                                        Click="UseScreenSuggestedAction_Click"
                                        ToolTip.Tip="{Binding PromptText}"
                                        Margin="0,0,8,8">
                                    <StackPanel Spacing="1">
                                        <TextBlock Text="{Binding Title}"
                                                   Classes="screenContextActionTitle"/>
                                        <TextBlock Text="{Binding KindText}"
                                                   Classes="screenContextActionMeta"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="当前步骤"
                               Classes="sectionTitle"/>
                    <TextBlock Text="{Binding ActiveStepText}"
                               Classes="bodyText"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding TaskProgressText}"
                           Foreground="{Binding StateAccentBrush}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </Grid>

            <ProgressBar Classes="compactProgress"
                         Value="{Binding CurrentProgress}"/>

            <controls:ComputerUsePanel IsVisible="{Binding IsComputerUsePanelVisible}"/>

            <Border Classes="confirmationCard"
                    IsVisible="{Binding IsWaitingForUserConfirmation}">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding PendingConfirmationTitle}"
                                   Foreground="{StaticResource Brush.Warning.Text}"
                                   FontSize="13"
                                   FontWeight="SemiBold"/>
                        <Border Grid.Column="1"
                                Background="{StaticResource Brush.Surface.Panel}"
                                CornerRadius="8"
                                Padding="7,2">
                            <TextBlock Text="{Binding PendingConfirmationRiskText}"
                                       Foreground="{StaticResource Brush.Warning.Text}"
                                       FontSize="10"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="{Binding PendingConfirmationDescription}"
                               Foreground="{StaticResource Brush.Text.Body}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding TaskActionStatus}"
                                   Classes="captionText"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="请在弹窗中确认"
                                   Foreground="{StaticResource Brush.Warning.Text}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <StackPanel Spacing="8">
                <TextBlock Text="步骤时间线"
                           Classes="sectionTitle"/>
                <ItemsControl ItemsSource="{Binding TaskTimeline}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:TaskTimelineItem">
                            <controls:TimelineItemView/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock Text="工具调用记录"
                           Classes="sectionTitle"/>
                <TextBlock Text="暂无调用记录"
                           Classes="captionText"
                           IsVisible="{Binding HasNoToolCallRecords}"/>
                <ItemsControl ItemsSource="{Binding TaskToolCalls}"
                              IsVisible="{Binding HasToolCallRecords}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:TaskToolCallItem">
                            <Border Classes="inlineCard"
                                    Margin="0,0,0,6">
                                <Grid ColumnDefinitions="*,Auto"
                                      RowDefinitions="Auto,Auto">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="6">
                                        <TextBlock Text="{Binding ToolName}"
                                                   Foreground="{StaticResource Brush.Text.Primary}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"/>
                                        <Border Background="{StaticResource Brush.Info.Surface}"
                                                CornerRadius="8"
                                                Padding="6,1">
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{StaticResource Brush.Info.Text}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding TimeText}"
                                               Classes="captionText"/>
                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="2"
                                               Text="{Binding Detail}"
                                               Classes="bodyText"
                                               Margin="0,4,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="任务结果"
                               Classes="sectionTitle"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding TaskResultStatusText}"
                               Classes="captionText"/>
                </Grid>

                <Border Classes="inlineCard">
                    <TextBlock Text="{Binding TaskResultPreview}"
                               Foreground="{StaticResource Brush.Text.Primary}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               MaxLines="6"/>
                </Border>

                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                    <TextBlock Text="{Binding TaskActionStatus}"
                               Classes="captionText"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                    <Button Grid.Column="1"
                            Content="复制"
                            Classes="secondaryAction"
                            Command="{Binding CopyTaskResultCommand}"
                            IsEnabled="{Binding CanUseTaskResultActions}"
                            Margin="8,0,0,0"/>
                    <Button Grid.Column="2"
                            Content="保存"
                            Classes="secondaryAction"
                            Command="{Binding SaveTaskResultCommand}"
                            IsEnabled="{Binding CanUseTaskResultActions}"
                            Margin="8,0,0,0"/>
                    <Button Grid.Column="3"
                            Content="重试"
                            Classes="primaryAction"
                            Command="{Binding RetryTaskCommand}"
                            Background="{Binding StateAccentBrush}"
                            IsVisible="{Binding CanRetryTask}"
                            Margin="8,0,0,0"
                            Padding="10,6"/>
                </Grid>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
