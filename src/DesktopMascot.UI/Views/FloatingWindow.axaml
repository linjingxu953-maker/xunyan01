<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DesktopMascot.UI.ViewModels"
        xmlns:controls="using:DesktopMascot.UI.Views.Controls"
        x:Class="DesktopMascot.UI.Views.FloatingWindow"
        x:DataType="vm:FloatingWindowViewModel"
        Title="DesktopMascot"
        Width="80" Height="80"
        WindowStartupLocation="Manual"
        Position="100,100"
        Background="Transparent"
        Topmost="True"
        WindowDecorations="None"
        TransparencyLevelHint="AcrylicBlur"
        CanResize="False"
        ShowInTaskbar="False"
        ClipToBounds="False">

    <Grid ClipToBounds="False">
        <!-- 角色图标 - 始终显示 -->
        <Border Classes="mascotIcon"
                IsVisible="{Binding IsMascotIconVisible}"
                PointerPressed="MascotIcon_PointerPressed"
                Cursor="Hand">
            <controls:MascotView Width="64" Height="64"/>
        </Border>

        <!-- 对话框 - 点击角色后显示 -->
        <Border Classes="chatDialog"
                IsVisible="{Binding IsChatDialogVisible}"
                IsHitTestVisible="{Binding IsChatDialogHitTestVisible}">
            <Grid RowDefinitions="36,*">
                <!-- 对话框标题栏 -->
                <Border Grid.Row="0"
                        Classes="dialogTitleBar"
                        PointerPressed="TitleBar_PointerPressed">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" Margin="8,0,8,0">
                        <!-- 左上角：设置按钮 -->
                        <Button Grid.Column="0"
                                Classes="iconButton"
                                Command="{Binding OpenSettingsCommand}"
                                Content="⚙"
                                FontSize="14"
                                Width="28" Height="28"
                                VerticalAlignment="Center"/>

                        <!-- 中间：角色名 -->
                        <TextBlock Grid.Column="1"
                                   Text="{Binding CharacterName}"
                                   Classes="dialogTitleText"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>

                        <!-- 右上角：最小化 -->
                        <Button Grid.Column="2"
                                Classes="iconButton"
                                Command="{Binding HideWindowCommand}"
                                Content="─"
                                FontSize="12"
                                Width="28" Height="28"
                                VerticalAlignment="Center"
                                Margin="0,0,4,0"/>

                        <!-- 右上角：关闭 -->
                        <Button Grid.Column="3"
                                Classes="iconButton"
                                Command="{Binding CollapseDialogCommand}"
                                Content="✕"
                                FontSize="12"
                                Width="28" Height="28"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- 聊天内容区 -->
                <controls:ChatPanel Grid.Row="1"
                                    x:Name="ChatPanel"/>
            </Grid>
        </Border>
    </Grid>
</Window>
