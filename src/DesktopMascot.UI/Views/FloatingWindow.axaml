<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DesktopMascot.UI.ViewModels"
        xmlns:controls="using:DesktopMascot.UI.Views.Controls"
        x:Class="DesktopMascot.UI.Views.FloatingWindow"
        x:DataType="vm:FloatingWindowViewModel"
        Title="DesktopMascot"
        Width="80" Height="80"
        WindowStartupLocation="Manual"
        Position="1800,900"
        Background="Transparent"
        Topmost="True"
        WindowDecorations="None"
        TransparencyLevelHint="AcrylicBlur"
        CanResize="False"
        ShowInTaskbar="False"
        ClipToBounds="False">

    <Grid ClipToBounds="False">
        <Border Classes="mascotIcon"
                IsVisible="{Binding IsMascotIconVisible}"
                PointerPressed="MascotIcon_PointerPressed"
                Cursor="Hand">
            <Image Source="{Binding CharacterImageSource}"
                   Width="64" Height="64"
                   Stretch="Uniform"/>
        </Border>

        <Border Classes="chatDialog"
                IsVisible="{Binding IsChatDialogVisible}"
                IsHitTestVisible="{Binding IsChatDialogHitTestVisible}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Classes="dialogTitleBar"
                        PointerPressed="TitleBar_PointerPressed">
                    <Grid Margin="12,0,12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Classes="iconButton"
                                Command="{Binding OpenSettingsCommand}"
                                Content="&#x2699;"
                                FontSize="16"
                                Width="32" Height="32"
                                VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding CharacterName}"
                                   Classes="dialogTitleText"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>
                        <Button Grid.Column="2"
                                Classes="iconButton"
                                Command="{Binding CollapseDialogCommand}"
                                Content="&#x2500;"
                                FontSize="14"
                                Width="32" Height="32"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"/>
                        <Button Grid.Column="3"
                                Classes="iconButton"
                                Command="{Binding ExitCommand}"
                                Content="&#x2715;"
                                FontSize="14"
                                Width="32" Height="32"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Classes="sidebarPanel"
                            IsVisible="{Binding IsSidebarVisible}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Text="历史对话"
                                       Classes="sidebarTitle"
                                       Margin="16,16,16,8"/>
                            <ScrollViewer Grid.Row="1">
                                <ItemsControl ItemsSource="{Binding TaskHistory}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:TaskHistoryItem">
                                            <Border Classes="historyItem"
                                                    PointerPressed="HistoryItem_PointerPressed"
                                                    Tag="{Binding}">
                                                <StackPanel Margin="12,10">
                                                    <TextBlock Text="{Binding Title}"
                                                               Classes="historyTitle"
                                                               MaxLines="1"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding TimeText}"
                                                               Classes="historyTime"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <Button Grid.Row="2"
                                    Content="+ 新建对话"
                                    Classes="newChatButton"
                                    Command="{Binding NewChatCommand}"
                                    Margin="12,8,12,12"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0"
                                      x:Name="MessageScrollViewer"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding MessageItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MessageItem">
                                        <Border Classes="messageBubble"
                                                Background="{Binding BubbleBackground}"
                                                Margin="12,4">
                                            <StackPanel Margin="12,10" Spacing="4">
                                                <TextBlock Text="{Binding RoleText}"
                                                           Classes="messageRole"
                                                           Foreground="{Binding RoleColor}"/>
                                                <TextBlock Text="{Binding Content}"
                                                           Classes="messageContent"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Border Grid.Row="1"
                                Classes="statusBar"
                                IsVisible="{Binding IsTaskActive}">
                            <Grid Margin="12,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Background="{Binding StateAccentBrush}"
                                        CornerRadius="10"
                                        Padding="10,4">
                                    <TextBlock Text="{Binding ActiveStepText}"
                                               Foreground="White"
                                               FontSize="11"
                                               FontWeight="SemiBold"/>
                                </Border>
                                <ProgressBar Grid.Column="1"
                                             Classes="compactProgress"
                                             Value="{Binding CurrentProgress}"
                                             Margin="12,0"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding TaskProgressText}"
                                           FontSize="11"
                                           Foreground="{StaticResource Brush.Text.Muted}"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Classes="inputArea">
                            <Grid Margin="12,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         x:Name="InputBox"
                                         Text="{Binding InputText}"
                                         Watermark="输入消息..."
                                         Classes="chatInput"
                                         KeyDown="InputBox_KeyDown"/>
                                <Button Grid.Column="1"
                                        Content="发送"
                                        Classes="sendButton"
                                        Command="{Binding SendMessageCommand}"
                                        IsEnabled="{Binding CanSendMessage}"
                                        Margin="8,0,0,0"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
