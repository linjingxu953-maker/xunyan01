<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DesktopMascot.UI.ViewModels"
        xmlns:controls="using:DesktopMascot.UI.Views.Controls"
        x:Class="DesktopMascot.UI.Views.FloatingWindow"
        x:DataType="vm:FloatingWindowViewModel"
        Title="寻研01"
        Width="180"
        Height="240"
        MinWidth="180"
        MinHeight="240"
        MaxWidth="980"
        MaxHeight="660"
        WindowStartupLocation="Manual"
        Background="Transparent"
        Topmost="True"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        CanResize="False"
        ShowInTaskbar="False"
        ClipToBounds="False">

    <Grid x:Name="WindowRoot"
          ClipToBounds="False">
                <Border x:Name="MascotHost"
                        Classes="mascotIcon"
                        Classes.busy="{Binding IsMascotBusy}"
                        Classes.waiting="{Binding IsMascotWaiting}"
                        Classes.error="{Binding IsMascotError}"
                        Classes.completed="{Binding IsMascotCompleted}"
                        IsVisible="{Binding IsMascotIconVisible}"
                        PointerPressed="MascotIcon_PointerPressed"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                ZIndex="2"
                Margin="0,0,4,4">
            <Grid>
                <Border x:Name="MascotHalo"
                        Classes="mascotHalo"/>
                <Border Classes="mascotPortrait">
                    <Image Source="{Binding CharacterImageSource}"
                           Stretch="Uniform"
                           UseLayoutRounding="True"
                           RenderOptions.BitmapInterpolationMode="HighQuality"
                           Margin="0"/>
                </Border>
                <TextBlock Text="{Binding CharacterAvatarText}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="{Binding StateAccentBrush}"
                           IsVisible="{Binding HasNoCharacterImage}"
                           IsHitTestVisible="False"/>
                <Border x:Name="MascotStateChip"
                        Classes="mascotStateChip"
                        Background="{Binding StateAccentBrush}">
                    <TextBlock Text="{Binding StateHint}"
                               Foreground="White"
                               FontSize="10"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </Border>

        <Border Classes="chatDialog"
                IsVisible="{Binding IsChatDialogVisible}"
                IsHitTestVisible="{Binding IsChatDialogHitTestVisible}"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                ZIndex="1">
            <Grid RowDefinitions="52,*">
                <Border Grid.Row="0"
                        Classes="dialogTitleBar"
                        PointerPressed="TitleBar_PointerPressed">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                          Margin="16,0,10,0">
                        <StackPanel VerticalAlignment="Center"
                                    Spacing="1"
                                    IsHitTestVisible="False">
                            <TextBlock Text="{Binding CharacterName}"
                                       Classes="dialogTitleText"/>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <TextBlock Text="{Binding CharacterRole}"
                                           Classes="dialogSubtitleText"/>
                                <TextBlock Text="{Binding CurrentStateText}"
                                           Classes="dialogSubtitleText"
                                           Foreground="{Binding StateAccentBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Classes="dialogIconButton"
                                Command="{Binding OpenSettingsCommand}"
                                Content="⚙"
                                Margin="0,0,4,0"/>
                        <Button Grid.Column="2"
                                Classes="dialogIconButton"
                                Command="{Binding CollapseDialogCommand}"
                                Content="─"
                                Margin="0,0,4,0"/>
                        <Button Grid.Column="3"
                                Classes="dialogIconButton"
                                Command="{Binding HideWindowCommand}"
                                Content="×"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="1"
                      ColumnDefinitions="172,*">
                    <Border Grid.Column="0"
                            Classes="sidebarPanel"
                            IsVisible="{Binding IsSidebarVisible}">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">
                            <TextBlock Grid.Row="0"
                                       Text="历史"
                                       Classes="sidebarTitle"
                                       Margin="16,16,16,4"/>
                            <Button Grid.Row="1"
                                    Content="+ 新建对话"
                                    Classes="newChatButton"
                                    Command="{Binding NewChatCommand}"
                                    Margin="12,8,12,10"/>
                            <Button Grid.Row="2"
                                    Content="工具入口"
                                    Classes="toolLauncherOpenButton"
                                    Command="{Binding ToggleToolLauncherCommand}"
                                    Margin="12,0,12,10"/>
                            <Border Grid.Row="3"
                                    Classes="characterSwitchPanel"
                                    Margin="12,0,12,10">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="角色"
                                                   Classes="sidebarTitle"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="1"
                                                Content="管理"
                                                Classes="characterManageButton"
                                                Command="{Binding OpenAppearanceSettingsCommand}"/>
                                    </Grid>
                                    <TextBlock Text="暂无可切换角色"
                                               Classes="sidebarEmptyText"
                                               IsVisible="{Binding HasNoCharacterSwitchItems}"/>
                                    <ScrollViewer MaxHeight="132"
                                                  VerticalScrollBarVisibility="Auto"
                                                  IsVisible="{Binding HasCharacterSwitchItems}">
                                        <ItemsControl ItemsSource="{Binding CharacterSwitchItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:CharacterProfileListItem">
                                                    <Button Classes="characterSwitchButton"
                                                            Classes.active="{Binding IsActive}"
                                                            Tag="{Binding}"
                                                            Click="CharacterSwitchItem_Click"
                                                            Margin="0,0,0,6">
                                                        <Grid ColumnDefinitions="34,*,Auto"
                                                              ColumnSpacing="8">
                                                            <Border Classes="characterSwitchAvatar"
                                                                    Background="{Binding AccentBrush}">
                                                                <Grid>
                                                                    <Image Source="{Binding Thumbnail}"
                                                                           Stretch="UniformToFill"
                                                                           IsVisible="{Binding HasThumbnail}"/>
                                                                    <TextBlock Text="{Binding AvatarText}"
                                                                               Classes="characterSwitchAvatarText"
                                                                               IsVisible="{Binding HasNoThumbnail}"/>
                                                                </Grid>
                                                            </Border>
                                                            <StackPanel Grid.Column="1"
                                                                        Spacing="1"
                                                                        VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Name}"
                                                                           Classes="characterSwitchName"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding Role}"
                                                                           Classes="characterSwitchRole"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding StateImageStatusText}"
                                                                           Classes="characterSwitchStateStatus"
                                                                           Foreground="{Binding StateImageStatusBrush}"
                                                                           ToolTip.Tip="{Binding MissingStateImageText}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding ActiveText}"
                                                                       Classes="characterSwitchActiveText"
                                                                       VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                            <TextBlock Grid.Row="4"
                                       Text="暂无历史对话"
                                       Classes="sidebarEmptyText"
                                       IsVisible="{Binding HasNoTaskHistory}"
                                       Margin="16,10,16,0"/>
                            <ScrollViewer Grid.Row="4"
                                          VerticalScrollBarVisibility="Auto"
                                          IsVisible="{Binding HasTaskHistory}">
                                <ItemsControl ItemsSource="{Binding TaskHistory}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:TaskHistoryItem">
                                            <Border Classes="historyItem"
                                                    Tag="{Binding}">
                                                <Expander>
                                                    <Expander.Header>
                                                        <StackPanel Margin="10,8"
                                                                    Spacing="3">
                                                            <TextBlock Text="{Binding Title}"
                                                                       Classes="historyTitle"
                                                                       MaxLines="2"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <Grid ColumnDefinitions="*,Auto">
                                                                <TextBlock Text="{Binding TimeText}"
                                                                           Classes="historyTime"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding MessageCountText}"
                                                                           Classes="historyTime"/>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Expander.Header>
                                                    <StackPanel Margin="10,0,10,10"
                                                                Spacing="8">
                                                        <TextBlock Text="{Binding PreviewText}"
                                                                   Classes="historyPreview"
                                                                   TextWrapping="Wrap"/>
                                                        <WrapPanel>
                                                            <Button Content="打开"
                                                                    Classes="historyActionButton"
                                                                    Tag="{Binding}"
                                                                    Click="OpenHistoryItem_Click"
                                                                    Margin="0,0,6,6"/>
                                                            <Button Content="复制"
                                                                    Classes="historyActionButton"
                                                                    Tag="{Binding}"
                                                                    Click="CopyHistoryItem_Click"
                                                                    Margin="0,0,6,6"/>
                                                            <Button Content="保存"
                                                                    Classes="historyActionButton"
                                                                    Tag="{Binding}"
                                                                    Click="SaveHistoryItem_Click"
                                                                    Margin="0,0,6,6"/>
                                                            <Button Content="删除"
                                                                    Classes="historyDangerButton"
                                                                    Tag="{Binding}"
                                                                    Click="DeleteHistoryItem_Click"
                                                                    Margin="0,0,6,6"/>
                                                        </WrapPanel>
                                                    </StackPanel>
                                                </Expander>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <TextBlock Grid.Row="5"
                                       Text="{Binding StateHint}"
                                       Classes="sidebarFooterText"
                                       Margin="16,10,16,14"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1">
                    <Grid RowDefinitions="*,Auto,Auto,Auto"
                          IsVisible="{Binding IsChatPageVisible}">
                        <Border Grid.Row="0"
                                Classes="messageList">
                            <Grid RowDefinitions="Auto,Auto,*">
                                <Border Grid.Row="0"
                                        Classes="screenSelectionContextCard"
                                        IsVisible="{Binding HasScreenSelectionContext}"
                                        Margin="18,16,18,4">
                                    <Grid ColumnDefinitions="*,Auto"
                                          RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                                        <StackPanel Grid.Row="0"
                                                    Grid.Column="0"
                                                    Spacing="3">
                                            <TextBlock Text="{Binding ScreenSelectionContext.Title}"
                                                       Classes="screenContextTitle"/>
                                            <TextBlock Text="{Binding ScreenSelectionContext.DetailText}"
                                                       Classes="screenContextBody"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Border Grid.Row="0"
                                                Grid.Column="1"
                                                Classes="screenContextBadge"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding ScreenSelectionContext.StatusText}"
                                                       Classes="screenContextBadgeText"/>
                                        </Border>
                                        <Grid Grid.Row="1"
                                              Grid.ColumnSpan="2"
                                              ColumnDefinitions="*,Auto"
                                              Margin="0,10,0,0">
                                            <TextBlock Text="{Binding ScreenSelectionContext.RegionText}"
                                                       Classes="screenContextMeta"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding ScreenSelectionContext.SizeText}"
                                                       Classes="screenContextMeta"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                        <Border Grid.Row="2"
                                                Grid.ColumnSpan="2"
                                                Classes="screenContextScreenshotRow"
                                                IsVisible="{Binding ScreenSelectionContext.HasScreenshotEvidence}"
                                                ToolTip.Tip="{Binding ScreenSelectionContext.ScreenshotPath}"
                                                Margin="0,10,0,0">
                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                  RowDefinitions="Auto,Auto"
                                                  ColumnSpacing="10"
                                                  RowSpacing="8">
                                                <Border Classes="screenContextPreviewFrame"
                                                        IsVisible="{Binding ScreenSelectionContext.HasScreenshotPreview}">
                                                    <Image Source="{Binding ScreenSelectionContext.ScreenshotPath, Converter={StaticResource ScreenshotPreviewConverter}}"
                                                           Width="96"
                                                           Height="58"
                                                           Stretch="UniformToFill"/>
                                                </Border>
                                                <StackPanel Grid.Column="1"
                                                            Spacing="2"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="截图证据"
                                                               Classes="screenContextDetailLabel"/>
                                                    <TextBlock Text="{Binding ScreenSelectionContext.ScreenshotFileName}"
                                                               Classes="screenContextDetailValue"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2"
                                                            Orientation="Horizontal"
                                                            Spacing="6"
                                                            VerticalAlignment="Center">
                                                    <Button Classes="screenContextEvidenceButton"
                                                            Content="{Binding ScreenScreenshotPreview.ToggleText}"
                                                            IsEnabled="{Binding ScreenScreenshotPreview.CanTogglePreview}"
                                                            Click="ToggleScreenScreenshotPreview_Click"/>
                                                    <Button Classes="screenContextEvidenceButton"
                                                            IsEnabled="{Binding ScreenScreenshotPreview.CanCopyPath}"
                                                            Click="CopyScreenScreenshotPath_Click">
                                                        复制路径
                                                    </Button>
                                                    <Button Classes="screenContextEvidenceButton"
                                                            Click="UseScreenScreenshotEvidence_Click">
                                                        引用截图
                                                    </Button>
                                                </StackPanel>
                                                <Border Grid.Row="1"
                                                        Grid.ColumnSpan="3"
                                                        Classes="screenContextExpandedPreviewFrame"
                                                        IsVisible="{Binding ScreenScreenshotPreview.ShowExpandedPreview}">
                                                    <Image Source="{Binding ScreenSelectionContext.ScreenshotPath, Converter={StaticResource ScreenshotPreviewConverter}}"
                                                           MaxHeight="220"
                                                           Stretch="Uniform"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <Expander Grid.Row="3"
                                                  Grid.ColumnSpan="2"
                                                  Classes="screenContextDetailsExpander"
                                                  IsVisible="{Binding ScreenSelectionContext.HasDetailItems}"
                                                  Margin="0,10,0,0">
                                            <Expander.Header>
                                                <TextBlock Text="查看识别详情"
                                                           Classes="screenContextMeta"/>
                                            </Expander.Header>
                                            <ItemsControl ItemsSource="{Binding ScreenSelectionContext.DetailItems}"
                                                          Margin="0,8,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:ScreenContextDetailItem">
                                                        <Border Classes="screenContextDetailRow"
                                                                Margin="0,0,0,6">
                                                            <Grid ColumnDefinitions="74,*"
                                                                  ColumnSpacing="8">
                                                                <TextBlock Text="{Binding Label}"
                                                                           Classes="screenContextDetailLabel"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Value}"
                                                                           Classes="screenContextDetailValue"
                                                                           TextWrapping="Wrap"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>
                                        <ItemsControl Grid.Row="4"
                                                      Grid.ColumnSpan="2"
                                                      ItemsSource="{Binding ScreenSelectionContext.SuggestedActions}"
                                                      IsVisible="{Binding ScreenSelectionContext.HasSuggestedActions}"
                                                      Margin="0,10,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ScreenContextActionItem">
                                                    <Button Classes="screenContextActionButton"
                                                            Tag="{Binding}"
                                                            Click="UseScreenSuggestedAction_Click"
                                                            ToolTip.Tip="{Binding PromptText}"
                                                            Margin="0,0,8,8">
                                                        <StackPanel Spacing="1">
                                                            <TextBlock Text="{Binding Title}"
                                                                       Classes="screenContextActionTitle"/>
                                                            <TextBlock Text="{Binding KindText}"
                                                                       Classes="screenContextActionMeta"/>
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1"
                                        Classes="toolLauncherPanel"
                                        IsVisible="{Binding IsToolLauncherVisible}"
                                        Margin="18,10,18,6">
                                    <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                                          RowSpacing="10">
                                        <Grid Grid.Row="0"
                                              ColumnDefinitions="*,Auto"
                                              ColumnSpacing="10">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="工具入口"
                                                           Classes="toolLauncherTitle"/>
                                                <TextBlock Text="选择一个工具后，会把任务模板填入输入框，继续走现有权限和 Agent 链路。"
                                                           Classes="toolLauncherCaption"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding ToolSearchText}"
                                                     Classes="toolLauncherSearchBox"
                                                     PlaceholderText="搜索工具"
                                                     Width="190"/>
                                        </Grid>

                                        <ScrollViewer Grid.Row="1"
                                                      HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{Binding ToolLauncherCategories}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding}"
                                                                Tag="{Binding}"
                                                                Classes="toolLauncherCategoryButton"
                                                                Click="SelectToolLauncherCategory_Click"
                                                                Margin="0,0,6,0"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>

                                        <Border Grid.Row="2"
                                                Classes="toolLauncherFormCard"
                                                IsVisible="{Binding HasToolLauncherForm}">
                                            <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                                                  RowSpacing="8">
                                                <Grid Grid.Row="0"
                                                      ColumnDefinitions="*,Auto"
                                                      ColumnSpacing="10">
                                                    <StackPanel Spacing="2">
                                                        <TextBlock Text="{Binding ToolLauncherFormTitle}"
                                                                   Classes="toolLauncherItemTitle"/>
                                                        <TextBlock Text="{Binding ToolLauncherFormDescription}"
                                                                   Classes="toolLauncherItemDescription"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding SelectedToolLauncherFormItem.RiskText}"
                                                               Classes="toolLauncherItemMeta"
                                                               VerticalAlignment="Top"/>
                                                </Grid>
                                                <Grid Grid.Row="1"
                                                      ColumnDefinitions="*,*"
                                                      ColumnSpacing="8">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Text="{Binding ToolLauncherPrimaryLabel}"
                                                                   Classes="toolLauncherFormLabel"/>
                                                        <Grid ColumnDefinitions="*,Auto,Auto"
                                                              ColumnSpacing="6">
                                                            <TextBox Text="{Binding ToolLauncherPrimaryInput}"
                                                                     Classes="toolLauncherFormInput"
                                                                     PlaceholderText="{Binding ToolLauncherPrimaryPlaceholder}"/>
                                                            <Button Grid.Column="1"
                                                                    Content="选文件"
                                                                    Classes="toolLauncherPathButton"
                                                                    IsVisible="{Binding IsToolLauncherPathForm}"
                                                                    Click="PickToolLauncherFilePath_Click"/>
                                                            <Button Grid.Column="2"
                                                                    Content="选目录"
                                                                    Classes="toolLauncherPathButton"
                                                                    IsVisible="{Binding IsToolLauncherPathForm}"
                                                                    Click="PickToolLauncherFolderPath_Click"/>
                                                        </Grid>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1"
                                                                Spacing="4">
                                                        <TextBlock Text="{Binding ToolLauncherSecondaryLabel}"
                                                                   Classes="toolLauncherFormLabel"/>
                                                        <TextBox Text="{Binding ToolLauncherSecondaryInput}"
                                                                 Classes="toolLauncherFormInput"
                                                                 PlaceholderText="{Binding ToolLauncherSecondaryPlaceholder}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Grid Grid.Row="2"
                                                      ColumnDefinitions="*,*"
                                                      ColumnSpacing="8">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Text="处理目标"
                                                                   Classes="toolLauncherFormLabel"/>
                                                        <TextBox Text="{Binding ToolLauncherObjectiveInput}"
                                                                 Classes="toolLauncherFormInput"
                                                                 PlaceholderText="例如：总结重点、修复问题、生成可提交结果"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1"
                                                                Spacing="4">
                                                        <TextBlock Text="期望输出"
                                                                   Classes="toolLauncherFormLabel"/>
                                                        <TextBox Text="{Binding ToolLauncherOutputInput}"
                                                                 Classes="toolLauncherFormInput"
                                                                 PlaceholderText="例如：简洁结论、Markdown、可执行步骤"/>
                                                    </StackPanel>
                                                </Grid>
                                                <Grid Grid.Row="3"
                                                      ColumnDefinitions="*,Auto"
                                                      ColumnSpacing="8">
                                                    <TextBlock Text="{Binding ToolLauncherFormHint}"
                                                               Classes="toolLauncherCaption"
                                                               TextWrapping="Wrap"
                                                               VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1"
                                                                Orientation="Horizontal"
                                                                Spacing="6">
                                                        <Button Content="取消"
                                                                Classes="toolLauncherSecondaryButton"
                                                                Click="CancelToolLauncherForm_Click"/>
                                                        <Button Content="填入输入框"
                                                                Classes="toolLauncherPrimaryButton"
                                                                IsEnabled="{Binding CanApplyToolLauncherForm}"
                                                                Click="ApplyToolLauncherForm_Click"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </Border>

                                        <Grid Grid.Row="3">
                                            <TextBlock Text="没有匹配的工具入口"
                                                       Classes="toolLauncherCaption"
                                                       IsVisible="{Binding HasNoToolLauncherResults}"/>
                                            <ScrollViewer MaxHeight="188"
                                                          VerticalScrollBarVisibility="Auto"
                                                          IsVisible="{Binding HasToolLauncherResults}">
                                                <ItemsControl ItemsSource="{Binding FilteredToolLauncherItems}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:ToolLauncherItem">
                                                            <Button Classes="toolLauncherItemButton"
                                                                    Tag="{Binding}"
                                                                    Click="UseToolLauncherItem_Click"
                                                                    ToolTip.Tip="{Binding LaunchPrompt}"
                                                                    Margin="0,0,8,8">
                                                                <StackPanel Spacing="5"
                                                                            Width="184">
                                                                    <Grid ColumnDefinitions="*,Auto">
                                                                        <TextBlock Text="{Binding Title}"
                                                                                   Classes="toolLauncherItemTitle"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                        <Border Grid.Column="1"
                                                                                Classes="toolLauncherBadge">
                                                                            <TextBlock Text="{Binding CategoryBadgeText}"
                                                                                       Classes="toolLauncherBadgeText"/>
                                                                        </Border>
                                                                    </Grid>
                                                                    <TextBlock Text="{Binding Description}"
                                                                               Classes="toolLauncherItemDescription"
                                                                               MaxLines="2"
                                                                               TextWrapping="Wrap"/>
                                                                    <TextBlock Text="{Binding RiskText}"
                                                                               Classes="toolLauncherItemMeta"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                </StackPanel>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Grid>
                                </Border>

                            <Grid Grid.Row="2">
                                <StackPanel IsVisible="{Binding HasNoMessages}"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Width="280"
                                            Spacing="8">
                                    <TextBlock Text="{Binding CharacterCatchphrase}"
                                               Classes="emptyChatTitle"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="输入任务后，我会在这里显示回复和执行状态。"
                                               Classes="emptyChatHint"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <ScrollViewer x:Name="MessageScrollViewer"
                                              VerticalScrollBarVisibility="Auto"
                                              IsVisible="{Binding HasMessages}">
                                    <ItemsControl ItemsSource="{Binding MessageItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:MessageItem">
                                                <StackPanel HorizontalAlignment="{Binding BubbleAlignment}"
                                                            MaxWidth="520"
                                                            Margin="18,7">
                                                    <TextBlock Text="{Binding RoleText}"
                                                               Classes="messageRole"
                                                               Foreground="{Binding RoleColor}"
                                                               HorizontalAlignment="{Binding BubbleAlignment}"/>
                                                    <Border Classes="messageBubble"
                                                            Background="{Binding BubbleBackground}"
                                                            CornerRadius="{Binding BubbleCornerRadius}">
                                                        <StackPanel Spacing="8">
                                                            <TextBlock Text="{Binding Content}"
                                                                       Classes="messageContent"
                                                                       Foreground="{Binding ContentBrush}"/>
                                                            <Button Content="朗读此回复"
                                                                    Classes="bubbleAudioButton"
                                                                    Click="PlayMessageButton_Click"
                                                                    Tag="{Binding Content}"
                                                                    IsVisible="{Binding IsAssistant}"
                                                                    HorizontalAlignment="Left"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                            </Grid>
                        </Border>

                        <controls:ComputerUsePanel Grid.Row="1"
                                                   Margin="14,0,14,10"
                                                   IsVisible="{Binding IsComputerUsePanelVisible}"/>

                        <Border Grid.Row="2"
                                Classes="statusBar"
                                IsVisible="{Binding IsTaskActive}">
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  Margin="14,9">
                                <Border Grid.Column="0"
                                        Background="{Binding StateAccentBrush}"
                                        CornerRadius="10"
                                        Padding="9,4">
                                    <TextBlock Text="{Binding ActiveStepText}"
                                               Foreground="White"
                                               FontSize="11"
                                               FontWeight="SemiBold"/>
                                </Border>
                                <ProgressBar Grid.Column="1"
                                             Classes="compactProgress"
                                             Value="{Binding CurrentProgress}"
                                             Margin="12,0"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding TaskProgressText}"
                                           Classes="statusPercentText"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3"
                                Classes="inputArea">
                            <StackPanel Margin="14,12"
                                        Spacing="8">
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                      ColumnSpacing="10">
                                    <Button Grid.Column="0"
                                            Content="{Binding VoiceInputButtonText}"
                                            Classes="voiceButton"
                                            Command="{Binding ToggleVoiceInputCommand}"/>
                                    <TextBox Grid.Column="1"
                                             x:Name="InputBox"
                                             Text="{Binding InputText}"
                                             PlaceholderText="输入任务或问题..."
                                             Classes="chatInput"
                                             KeyDown="InputBox_KeyDown"/>
                                    <Button Grid.Column="2"
                                            Content="{Binding VoiceReplyButtonText}"
                                            Classes="voiceButton"
                                            Command="{Binding StopVoiceReplyCommand}"
                                            IsEnabled="{Binding CanStopVoiceReply}"/>
                                    <Button Grid.Column="3"
                                            Content="发送"
                                            Classes="sendButton"
                                            Command="{Binding SendMessageCommand}"
                                            IsEnabled="{Binding CanSendMessage}"/>
                                </Grid>
                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="10">
                                    <TextBlock Text="{Binding VoiceInputStatus}"
                                               Classes="voiceStatusText"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding VoiceReplyStatus}"
                                               Classes="voiceStatusText"
                                               TextTrimming="CharacterEllipsis"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid RowDefinitions="Auto,*"
                          IsVisible="{Binding IsSettingsPageVisible}">
                        <Border Grid.Row="0"
                                Classes="inlineSettingsHeader">
                            <Grid ColumnDefinitions="*,Auto"
                                  Margin="18,14">
                                <StackPanel Spacing="3">
                                    <TextBlock Text="{Binding InlineSettingsTitle}"
                                               Classes="inlineSettingsTitle"/>
                                    <TextBlock Text="{Binding InlineSettingsDescription}"
                                               Classes="inlineSettingsSubtitle"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="返回对话"
                                        Classes="inlineSettingsBackButton"
                                        Command="{Binding BackToChatCommand}"
                                        VerticalAlignment="Top"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1"
                              ColumnDefinitions="142,*">
                            <Border Grid.Column="0"
                                    Classes="inlineSettingsNav">
                                <StackPanel Margin="12,14"
                                            Spacing="7">
                                    <Button Content="总览"
                                            Classes="inlineSettingsNavButton"
                                            Command="{Binding SelectInlineSettingsSectionCommand}"
                                            CommandParameter="overview"/>
                                    <Button Content="模型"
                                            Classes="inlineSettingsNavButton"
                                            Command="{Binding SelectInlineSettingsSectionCommand}"
                                            CommandParameter="model"/>
                                    <Button Content="Mimo Code"
                                            Classes="inlineSettingsNavButton"
                                            Command="{Binding SelectInlineSettingsSectionCommand}"
                                            CommandParameter="mimoCode"/>
                                    <Button Content="权限"
                                            Classes="inlineSettingsNavButton"
                                            Command="{Binding SelectInlineSettingsSectionCommand}"
                                            CommandParameter="permission"/>
                                    <Button Content="记忆"
                                            Classes="inlineSettingsNavButton"
                                            Command="{Binding SelectInlineSettingsSectionCommand}"
                                            CommandParameter="memory"/>
                                    <Button Content="快捷键"
                                            Classes="inlineSettingsNavButton"
                                            Command="{Binding SelectInlineSettingsSectionCommand}"
                                            CommandParameter="hotkey"/>
                                    <Button Content="角色外观"
                                            Classes="inlineSettingsNavButton"
                                            Command="{Binding SelectInlineSettingsSectionCommand}"
                                            CommandParameter="appearance"/>
                                    <Button Content="日志/数据"
                                            Classes="inlineSettingsNavButton"
                                            Command="{Binding SelectInlineSettingsSectionCommand}"
                                            CommandParameter="data"/>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Column="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          IsEnabled="{Binding InlineSettings.IsNotBusy}">
                                <StackPanel Margin="18"
                                            Spacing="14">
                                    <StackPanel Spacing="12"
                                                IsVisible="{Binding InlineSettings.IsOverviewSectionSelected}">
                                        <Border Classes="inlineSettingsCard">
                                            <StackPanel Spacing="10">
                                                <TextBlock Text="{Binding InlineSettings.RuntimeOverviewStatus}"
                                                           Classes="inlineSettingsBody"
                                                           TextWrapping="Wrap"/>
                                                <ItemsControl ItemsSource="{Binding InlineSettings.RuntimeOverviewItems}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SettingsListItem">
                                                            <Border Background="#0FFFFFFF"
                                                                    BorderBrush="#18FFFFFF"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8"
                                                                    Padding="10"
                                                                    Margin="0,0,0,8">
                                                                <StackPanel Spacing="4">
                                                                    <Grid ColumnDefinitions="*,Auto">
                                                                        <TextBlock Text="{Binding Title}"
                                                                                   Classes="inlineSettingsCardTitle"/>
                                                                        <TextBlock Grid.Column="1"
                                                                                   Text="{Binding Value}"
                                                                                   Classes="inlineSettingsBody"
                                                                                   HorizontalAlignment="Right"/>
                                                                    </Grid>
                                                                    <TextBlock Text="{Binding Description}"
                                                                               Classes="inlineSettingsBody"
                                                                               TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Spacing="12"
                                                IsVisible="{Binding InlineSettings.IsModelSectionSelected}">
                                        <Border Classes="inlineSettingsCard">
                                            <StackPanel Spacing="10">
                                                <ComboBox ItemsSource="{Binding InlineSettings.Providers}"
                                                          SelectedItem="{Binding InlineSettings.SelectedProvider}"
                                                          MinWidth="260"/>
                                                <TextBox Text="{Binding InlineSettings.ApiKey}"
                                                         PasswordChar="*"
                                                         PlaceholderText="API Key"/>
                                                <TextBox Text="{Binding InlineSettings.ApiEndpoint}"
                                                         PlaceholderText="Base URL"/>
                                                <TextBox Text="{Binding InlineSettings.ModelName}"
                                                         PlaceholderText="模型名"/>
                                                <TextBlock Text="{Binding InlineSettings.ModelSettingsStatus}"
                                                           Classes="inlineSettingsBody"
                                                           TextWrapping="Wrap"/>
                                                <Grid ColumnDefinitions="*,*"
                                                      ColumnSpacing="8">
                                                    <ComboBox ItemsSource="{Binding InlineSettings.TtsVoiceOptions}"
                                                              SelectedItem="{Binding InlineSettings.TtsVoice}"/>
                                                    <ComboBox Grid.Column="1"
                                                              ItemsSource="{Binding InlineSettings.SpeechRecognitionLanguageOptions}"
                                                              SelectedItem="{Binding InlineSettings.SpeechRecognitionLanguage}"/>
                                                </Grid>
                                                <TextBlock Text="{Binding InlineSettings.VoiceConfigurationSummary}"
                                                           Classes="inlineSettingsBody"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding InlineSettings.SpeechRecognitionLanguageDescription}"
                                                           Classes="inlineSettingsBody"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding InlineSettings.VoiceSettingsStatus}"
                                                           Classes="inlineSettingsBody"
                                                           TextWrapping="Wrap"/>
                                                <Grid ColumnDefinitions="*,Auto,Auto"
                                                      ColumnSpacing="8">
                                                    <TextBlock Text="{Binding InlineSettings.TtsPreviewText}"
                                                               Classes="inlineSettingsBody"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap"/>
                                                    <Button Grid.Column="1"
                                                            Content="预览语音"
                                                            Classes="inlineSettingsBackButton"
                                                            Command="{Binding InlineSettings.PreviewTtsVoiceCommand}"/>
                                                    <Button Grid.Column="2"
                                                            Content="保存语音"
                                                            Classes="inlineSettingsBackButton"
                                                            Command="{Binding InlineSettings.SaveVoiceSettingsCommand}"/>
                                                </Grid>
                                                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                                    <TextBlock Text="模型配置保存到本机，应用不内置 API Key。"
                                                               Classes="inlineSettingsBody"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap"/>
                                                    <Button Grid.Column="1"
                                                            Content="填入默认"
                                                            Classes="inlineSettingsBackButton"
                                                            Command="{Binding InlineSettings.UseProviderDefaultsCommand}"
                                                            Margin="8,0,0,0"/>
                                                    <Button Grid.Column="2"
                                                            Content="测试连接"
                                                            Classes="inlineSettingsBackButton"
                                                            Command="{Binding InlineSettings.TestConnectionCommand}"
                                                            Margin="8,0,0,0"/>
                                                    <Button Grid.Column="3"
                                                            Content="保存"
                                                            Classes="sendButton"
                                                            Command="{Binding InlineSettings.SaveModelSettingsCommand}"
                                                            Margin="8,0,0,0"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Spacing="12"
                                                IsVisible="{Binding InlineSettings.IsMimoCodeSectionSelected}">
                                        <Border Classes="inlineSettingsCard">
                                            <StackPanel Spacing="10">
                                                <CheckBox Content="启用 Mimo Code connector"
                                                          IsChecked="{Binding InlineSettings.IsMimoCodeEnabled}"/>
                                                <TextBox Text="{Binding InlineSettings.MimoCodeExecutablePath}"
                                                         PlaceholderText="可执行路径，例如 mimo"/>
                                                <TextBox Text="{Binding InlineSettings.MimoCodeWorkspacePath}"
                                                         PlaceholderText="工作目录，留空使用当前项目目录"/>
                                                <TextBlock Text="{Binding InlineSettings.MimoCodeStatus}"
                                                           Classes="inlineSettingsBody"
                                                           TextWrapping="Wrap"/>
                                                <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                                                    <TextBlock Text="模型调用仍使用用户自己的 API 配置。"
                                                               Classes="inlineSettingsBody"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap"/>
                                                    <Button Grid.Column="1"
                                                            Content="App Provider"
                                                            Classes="inlineSettingsBackButton"
                                                            Command="{Binding InlineSettings.UseAppProviderForMimoCodeCommand}"
                                                            Margin="8,0,0,0"/>
                                                    <Button Grid.Column="2"
                                                            Content="本机配置"
                                                            Classes="inlineSettingsBackButton"
                                                            Command="{Binding InlineSettings.UseMimoLocalConfigCommand}"
                                                            Margin="8,0,0,0"/>
                                                    <Button Grid.Column="3"
                                                            Content="检测"
                                                            Classes="inlineSettingsBackButton"
                                                            Command="{Binding InlineSettings.TestMimoCodeConnectionCommand}"
                                                            Margin="8,0,0,0"/>
                                                    <Button Grid.Column="4"
                                                            Content="保存"
                                                            Classes="sendButton"
                                                            Command="{Binding InlineSettings.SaveMimoCodeSettingsCommand}"
                                                            Margin="8,0,0,0"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Spacing="12"
                                                IsVisible="{Binding InlineSettings.IsPermissionSectionSelected}">
                                        <Border Classes="inlineSettingsCard">
                                            <StackPanel Spacing="10">
                                                <ComboBox ItemsSource="{Binding InlineSettings.PermissionAutoApproveLevels}"
                                                          SelectedItem="{Binding InlineSettings.SelectedAutoApproveLevel}"
                                                          MinWidth="260"/>
                                                <TextBox Text="{Binding InlineSettings.AuditLogRetentionDays}"
                                                         PlaceholderText="审计保留天数"/>
                                                <TextBlock Text="{Binding InlineSettings.PermissionSettingsStatus}"
                                                           Classes="inlineSettingsBody"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="M29 权限确认入口已接入，策略保存到本机。"
                                                           Classes="inlineSettingsBody"
                                                           TextWrapping="Wrap"/>
                                                <WrapPanel>
                                                    <Button Content="刷新"
                                                            Classes="inlineSettingsBackButton"
                                                            Command="{Binding InlineSettings.RefreshPermissionStatusCommand}"
                                                            Margin="0,0,8,8"/>
                                                    <Button Content="永久授权"
                                                            Classes="inlineSettingsBackButton"
                                                            Command="{Binding InlineSettings.ManagePermanentPermissionsCommand}"
                                                            Margin="0,0,8,8"/>
                                                    <Button Content="审计日志"
                                                            Classes="inlineSettingsBackButton"
                                                            Command="{Binding InlineSettings.OpenPermissionAuditCommand}"
                                                            Margin="0,0,8,8"/>
                                                    <Button Content="保存"
                                                            Classes="sendButton"
                                                            Command="{Binding InlineSettings.SavePermissionSettingsCommand}"
                                                            Margin="0,0,8,8"/>
                                                </WrapPanel>
                                                <TextBlock Text="最近审计"
                                                           Classes="inlineSettingsCardTitle"/>
                                                <ItemsControl ItemsSource="{Binding InlineSettings.PermissionAuditItems}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SettingsListItem">
                                                            <Grid ColumnDefinitions="88,76,*"
                                                                  ColumnSpacing="8"
                                                                  Margin="0,0,0,7">
                                                                <TextBlock Text="{Binding Title}"
                                                                           Classes="inlineSettingsBody"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Value}"
                                                                           Classes="inlineSettingsBody"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding Description}"
                                                                           Classes="inlineSettingsBody"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Spacing="12"
                                                IsVisible="{Binding InlineSettings.IsMemorySectionSelected}">
                                        <Border Classes="inlineSettingsCard">
                                            <StackPanel Spacing="10">
                                                <CheckBox Content="启用记忆"
                                                          IsChecked="{Binding InlineSettings.IsMemoryEnabled}"/>
                                                <TextBlock Text="{Binding InlineSettings.MemorySettingsStatus}"
                                                           Classes="inlineSettingsBody"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="M30 记忆确认接口已接入，操作会给出状态反馈。"
                                                           Classes="inlineSettingsBody"
                                                           TextWrapping="Wrap"/>
                                                <WrapPanel>
                                                    <Button Content="刷新"
                                                            Classes="inlineSettingsBackButton"
                                                            Command="{Binding InlineSettings.RefreshMemoryStatusCommand}"
                                                            Margin="0,0,8,8"/>
                                                    <Button Content="浏览"
                                                            Classes="inlineSettingsBackButton"
                                                            Command="{Binding InlineSettings.OpenMemoryBrowserCommand}"
                                                            Margin="0,0,8,8"/>
                                                    <Button Content="导出"
                                                            Classes="inlineSettingsBackButton"
                                                            Command="{Binding InlineSettings.ExportMemoryCommand}"
                                                            Margin="0,0,8,8"/>
                                                    <Button Content="导入"
                                                            Classes="inlineSettingsBackButton"
                                                            Command="{Binding InlineSettings.ImportMemoryCommand}"
                                                            Margin="0,0,8,8"/>
                                                    <Button Content="保存"
                                                            Classes="sendButton"
                                                            Command="{Binding InlineSettings.SaveMemorySettingsCommand}"
                                                            Margin="0,0,8,8"/>
                                                </WrapPanel>
                                                <TextBlock Text="记忆统计"
                                                           Classes="inlineSettingsCardTitle"/>
                                                <ItemsControl ItemsSource="{Binding InlineSettings.MemoryStatsItems}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SettingsListItem">
                                                            <Grid ColumnDefinitions="82,54,*"
                                                                  ColumnSpacing="8"
                                                                  Margin="0,0,0,7">
                                                                <TextBlock Text="{Binding Title}"
                                                                           Classes="inlineSettingsBody"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Value}"
                                                                           Classes="inlineSettingsBody"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding Description}"
                                                                           Classes="inlineSettingsBody"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <TextBlock Text="待确认记忆"
                                                           Classes="inlineSettingsCardTitle"/>
                                                <TextBlock Text="当前没有待确认记忆。"
                                                           Classes="inlineSettingsBody"
                                                           IsVisible="{Binding InlineSettings.HasNoPendingMemoryReviews}"/>
                                                <ItemsControl ItemsSource="{Binding InlineSettings.PendingMemoryReviews}"
                                                              IsVisible="{Binding InlineSettings.HasPendingMemoryReviews}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:PendingMemoryReviewItem">
                                                            <Grid RowDefinitions="Auto,Auto"
                                                                  Margin="0,0,0,8">
                                                                <Grid ColumnDefinitions="*,Auto"
                                                                      ColumnSpacing="8">
                                                                    <TextBlock Text="{Binding Key}"
                                                                               Classes="inlineSettingsBody"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding Status}"
                                                                               Classes="inlineSettingsBody"/>
                                                                </Grid>
                                                                <TextBlock Grid.Row="1"
                                                                           Text="{Binding Content}"
                                                                           Classes="inlineSettingsBody"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <TextBlock Text="最近记忆"
                                                           Classes="inlineSettingsCardTitle"/>
                                                <ItemsControl ItemsSource="{Binding InlineSettings.MemoryActionItems}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:SettingsListItem">
                                                            <Grid ColumnDefinitions="*,68"
                                                                  RowDefinitions="Auto,Auto"
                                                                  ColumnSpacing="8"
                                                                  Margin="0,0,0,8">
                                                                <TextBlock Text="{Binding Title}"
                                                                           Classes="inlineSettingsBody"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Value}"
                                                                           Classes="inlineSettingsBody"
                                                                           HorizontalAlignment="Right"/>
                                                                <TextBlock Grid.Row="1"
                                                                           Grid.ColumnSpan="2"
                                                                           Text="{Binding Description}"
                                                                           Classes="inlineSettingsBody"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Spacing="12"
                                                IsVisible="{Binding InlineSettings.IsHotkeySectionSelected}">
                                        <Border Classes="inlineSettingsCard">
                                            <StackPanel Spacing="10">
                                                <TextBox Text="{Binding InlineSettings.ChatHotkeyText}"
                                                         PlaceholderText="聊天唤起快捷键，例如 Ctrl+Alt+Space"/>
                                                <TextBox Text="{Binding InlineSettings.ScreenSelectionHotkeyText}"
                                                         PlaceholderText="屏幕圈选快捷键，例如 Ctrl+Shift+S"/>
                                                <TextBlock Text="{Binding InlineSettings.HotkeySettingsStatus}"
                                                           Classes="inlineSettingsBody"
                                                           TextWrapping="Wrap"/>
                                                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                                    <TextBlock Text="保存时会检测格式、冲突和注册结果。"
                                                               Classes="inlineSettingsBody"
                                                               TextWrapping="Wrap"
                                                               VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1"
                                                            Content="刷新"
                                                            Classes="inlineSettingsBackButton"
                                                            Command="{Binding InlineSettings.RefreshHotkeyStatusCommand}"
                                                            Margin="8,0,0,0"/>
                                                    <Button Grid.Column="2"
                                                            Content="恢复默认"
                                                            Classes="inlineSettingsBackButton"
                                                            Command="{Binding InlineSettings.ResetHotkeySettingsCommand}"
                                                            Margin="8,0,0,0"/>
                                                    <Button Grid.Column="3"
                                                            Content="保存"
                                                            Classes="sendButton"
                                                            Command="{Binding InlineSettings.SaveHotkeySettingsCommand}"
                                                            Margin="8,0,0,0"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Spacing="12"
                                                IsVisible="{Binding InlineSettings.IsAppearanceSectionSelected}">
                                        <Border Classes="inlineSettingsCard">
                                            <Grid ColumnDefinitions="150,*"
                                                  ColumnSpacing="14">
                                                <Border Width="134"
                                                        Height="188"
                                                        Classes="characterDropZone"
                                                        Background="Transparent"
                                                        ClipToBounds="False"
                                                        DragDrop.AllowDrop="True"
                                                        DragDrop.DragOver="InlineCharacterAssetDropZone_DragOver"
                                                        DragDrop.Drop="InlineCharacterAssetDropZone_Drop">
                                                    <Grid>
                                                        <Image Source="{Binding InlineSettings.CharacterImageSource}"
                                                               Stretch="Uniform"
                                                               UseLayoutRounding="True"
                                                               RenderOptions.BitmapInterpolationMode="HighQuality"
                                                               IsVisible="{Binding InlineSettings.HasCharacterImage}"/>
                                                        <TextBlock Text="{Binding InlineSettings.CharacterAvatarText}"
                                                                   Foreground="{Binding InlineSettings.CharacterAccentBrush}"
                                                                   FontSize="30"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   IsVisible="{Binding InlineSettings.HasNoCharacterImage}"/>
                                                        <Border Classes="characterDropHint"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Bottom"
                                                                Margin="8"
                                                                IsHitTestVisible="False">
                                                            <TextBlock Text="拖入图片"
                                                                       Classes="captionText"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Grid.Column="1"
                                                            Spacing="9">
                                                    <Grid ColumnDefinitions="*,*"
                                                          RowDefinitions="Auto,Auto,Auto,Auto"
                                                          ColumnSpacing="8"
                                                          RowSpacing="8">
                                                        <TextBox Text="{Binding InlineSettings.CharacterName}"
                                                                 PlaceholderText="角色名"/>
                                                        <TextBox Grid.Column="1"
                                                                 Text="{Binding InlineSettings.CharacterAvatarText}"
                                                                 PlaceholderText="头像文字"/>
                                                        <TextBox Grid.Row="1"
                                                                 Text="{Binding InlineSettings.CharacterRole}"
                                                                 PlaceholderText="角色定位"/>
                                                        <TextBox Grid.Row="1"
                                                                 Grid.Column="1"
                                                                 Text="{Binding InlineSettings.CharacterPersonality}"
                                                                 PlaceholderText="气质"/>
                                                        <TextBox Grid.Row="2"
                                                                 Grid.ColumnSpan="2"
                                                                 Text="{Binding InlineSettings.CharacterDescription}"
                                                                 PlaceholderText="角色描述"/>
                                                        <TextBox Grid.Row="3"
                                                                 Grid.ColumnSpan="2"
                                                                 Text="{Binding InlineSettings.CharacterCatchphrase}"
                                                                 PlaceholderText="口头禅"/>
                                                    </Grid>
                                                    <Border Classes="inlineSettingsInnerCard">
                                                        <StackPanel Spacing="9">
                                                            <Grid ColumnDefinitions="*,*,*"
                                                                  ColumnSpacing="8">
                                                                <ComboBox ItemsSource="{Binding InlineSettings.CharacterToneStyleOptions}"
                                                                          SelectedItem="{Binding InlineSettings.CharacterToneStyle}"/>
                                                                <ComboBox Grid.Column="1"
                                                                          ItemsSource="{Binding InlineSettings.CharacterLanguageStyleOptions}"
                                                                          SelectedItem="{Binding InlineSettings.CharacterLanguageStyle}"/>
                                                                <ComboBox Grid.Column="2"
                                                                          ItemsSource="{Binding InlineSettings.CharacterReplyLengthOptions}"
                                                                          SelectedItem="{Binding InlineSettings.CharacterReplyLength}"/>
                                                            </Grid>
                                                            <ItemsControl ItemsSource="{Binding InlineSettings.CharacterTraitOptions}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="vm:CharacterTraitOption">
                                                                        <CheckBox Content="{Binding Title}"
                                                                                  IsChecked="{Binding IsSelected}"
                                                                                  Margin="0,0,10,6"/>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <CheckBox Content="允许少量 emoji"
                                                                      IsChecked="{Binding InlineSettings.CharacterUseEmoji}"/>
                                                            <TextBox Text="{Binding InlineSettings.CharacterSystemPromptSuffix}"
                                                                     PlaceholderText="自定义系统提示词后缀（高级）"
                                                                     AcceptsReturn="True"
                                                                     TextWrapping="Wrap"
                                                                     MinHeight="62"
                                                                     MaxLength="500"/>
                                                            <Grid ColumnDefinitions="*,Auto">
                                                                <TextBlock Text="{Binding InlineSettings.CharacterStylePreview}"
                                                                           Classes="inlineSettingsBody"
                                                                           TextWrapping="Wrap"
                                                                           VerticalAlignment="Center"/>
                                                                <Button Grid.Column="1"
                                                                        Content="预览"
                                                                        Classes="inlineSettingsBackButton"
                                                                        Command="{Binding InlineSettings.PreviewCharacterStyleCommand}"
                                                                        Margin="8,0,0,0"/>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>
                                                    <Grid ColumnDefinitions="*,Auto"
                                                          RowDefinitions="Auto,Auto"
                                                          ColumnSpacing="8"
                                                          RowSpacing="8">
                                                        <TextBox Text="{Binding InlineSettings.CharacterImageFolder}"
                                                                 PlaceholderText="角色图片目录"
                                                                 MaxLength="260"/>
                                                        <Button Grid.Column="1"
                                                                Content="选择目录"
                                                                Classes="inlineSettingsBackButton"
                                                                Command="{Binding InlineSettings.PickCharacterImageFolderCommand}"/>
                                                        <TextBox Grid.Row="1"
                                                                 Text="{Binding InlineSettings.CharacterAvatarImage}"
                                                                 PlaceholderText="头像图片文件名"
                                                                 MaxLength="160"/>
                                                        <Button Grid.Row="1"
                                                                Grid.Column="1"
                                                                Content="选择头像"
                                                                Classes="inlineSettingsBackButton"
                                                                Command="{Binding InlineSettings.PickCharacterAvatarImageCommand}"/>
                                                    </Grid>
                                                    <Grid ColumnDefinitions="*,Auto"
                                                          ColumnSpacing="8">
                                                        <ComboBox ItemsSource="{Binding InlineSettings.CharacterStateImageItems}"
                                                                  SelectedItem="{Binding InlineSettings.SelectedCharacterStateImage}"
                                                                  MinWidth="180"/>
                                                        <Button Grid.Column="1"
                                                                Content="选择状态图"
                                                                Classes="inlineSettingsBackButton"
                                                                Command="{Binding InlineSettings.PickSelectedStateImageCommand}"/>
                                                    </Grid>
                                                    <TextBlock Text="{Binding InlineSettings.CharacterSaveStatus}"
                                                               Classes="inlineSettingsBody"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding InlineSettings.CharacterImageStatus}"
                                                               Classes="inlineSettingsBody"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding InlineSettings.CharacterAssetSuggestionStatus}"
                                                               Classes="inlineSettingsBody"
                                                               TextWrapping="Wrap"/>
                                                    <Border Classes="inlineSettingsInnerCard">
                                                        <StackPanel Spacing="8">
                                                            <Grid ColumnDefinitions="*,Auto"
                                                                  ColumnSpacing="8">
                                                                <StackPanel Spacing="2">
                                                                    <TextBlock Text="角色库"
                                                                               Classes="inlineSettingsCardTitle"
                                                                               FontSize="12"/>
                                                                    <TextBlock Text="{Binding InlineSettings.CharacterLibraryStatus}"
                                                                               Classes="inlineSettingsBody"
                                                                               TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                                <Button Grid.Column="1"
                                                                        Content="刷新"
                                                                        Classes="inlineSettingsBackButton"
                                                                        Command="{Binding InlineSettings.RefreshCharacterProfileLibraryCommand}"/>
                                                            </Grid>
                                                            <TextBlock Text="暂无保存的角色档案。"
                                                                       Classes="inlineSettingsBody"
                                                                       IsVisible="{Binding InlineSettings.HasNoCharacterProfiles}"/>
                                                            <ListBox ItemsSource="{Binding InlineSettings.CharacterProfiles}"
                                                                     SelectedItem="{Binding InlineSettings.SelectedCharacterProfile}"
                                                                     IsVisible="{Binding InlineSettings.HasCharacterProfiles}"
                                                                     MinHeight="88"
                                                                     MaxHeight="132">
                                                                <ListBox.ItemTemplate>
                                                                    <DataTemplate x:DataType="vm:CharacterProfileListItem">
                                                                        <Grid ColumnDefinitions="34,*,Auto"
                                                                              ColumnSpacing="8"
                                                                              Margin="0,4">
                                                                            <Border Classes="characterSwitchAvatar"
                                                                                    Background="{Binding AccentBrush}">
                                                                                <Grid>
                                                                                    <Image Source="{Binding Thumbnail}"
                                                                                           Stretch="UniformToFill"
                                                                                           IsVisible="{Binding HasThumbnail}"/>
                                                                                    <TextBlock Text="{Binding AvatarText}"
                                                                                               Classes="characterSwitchAvatarText"
                                                                                               IsVisible="{Binding HasNoThumbnail}"/>
                                                                                </Grid>
                                                                            </Border>
                                                                            <StackPanel Grid.Column="1"
                                                                                        Spacing="1"
                                                                                        VerticalAlignment="Center">
                                                                                <TextBlock Text="{Binding Name}"
                                                                                           Classes="characterSwitchName"
                                                                                           TextTrimming="CharacterEllipsis"/>
                                                                                <TextBlock Text="{Binding Role}"
                                                                                           Classes="characterSwitchRole"
                                                                                           TextTrimming="CharacterEllipsis"/>
                                                                            </StackPanel>
                                                                            <TextBlock Grid.Column="2"
                                                                                       Text="{Binding ActiveText}"
                                                                                       Classes="characterSwitchActiveText"
                                                                                       VerticalAlignment="Center"/>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ListBox.ItemTemplate>
                                                            </ListBox>
                                                            <Grid ColumnDefinitions="*,Auto,Auto"
                                                                  ColumnSpacing="8">
                                                                <TextBox Text="{Binding InlineSettings.CharacterProfileNameDraft}"
                                                                         PlaceholderText="角色档案名称"
                                                                         MaxLength="24"/>
                                                                <Button Grid.Column="1"
                                                                        Content="载入"
                                                                        Classes="sendButton"
                                                                        Command="{Binding InlineSettings.LoadSelectedCharacterProfileCommand}"/>
                                                                <Button Grid.Column="2"
                                                                        Content="存入"
                                                                        Classes="inlineSettingsBackButton"
                                                                        Command="{Binding InlineSettings.SaveCharacterProfileCommand}"/>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Classes="inlineSettingsInnerCard">
                                                        <StackPanel Spacing="8">
                                                            <Grid ColumnDefinitions="*,Auto"
                                                                  ColumnSpacing="8">
                                                                <StackPanel Spacing="2">
                                                                    <TextBlock Text="状态图预览"
                                                                               Classes="inlineSettingsCardTitle"
                                                                               FontSize="12"/>
                                                                    <TextBlock Text="{Binding InlineSettings.CharacterStatePreviewStatus}"
                                                                               Classes="inlineSettingsBody"
                                                                               TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                                <Button Grid.Column="1"
                                                                        Content="刷新状态图"
                                                                        Classes="inlineSettingsBackButton"
                                                                        Command="{Binding InlineSettings.RefreshCharacterStatePreviewCommand}"/>
                                                            </Grid>
                                                            <ItemsControl ItemsSource="{Binding InlineSettings.CharacterStatePreviewItems}"
                                                                          IsVisible="{Binding InlineSettings.HasCharacterStatePreviews}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="vm:CharacterStatePreviewItem">
                                                                        <Border Classes="characterStatePreviewCard"
                                                                                Margin="0,0,8,8">
                                                                            <Grid RowDefinitions="86,Auto,Auto"
                                                                                  RowSpacing="6">
                                                                                <Border Classes="characterStatePreviewImageFrame">
                                                                                    <Grid>
                                                                                        <Image Source="{Binding Image}"
                                                                                               Stretch="Uniform"
                                                                                               IsVisible="{Binding HasImage}"/>
                                                                                        <TextBlock Text="{Binding PreviewText}"
                                                                                                   Classes="characterStatePreviewPlaceholder"
                                                                                                   IsVisible="{Binding HasNoImage}"/>
                                                                                    </Grid>
                                                                                </Border>
                                                                                <Grid Grid.Row="1"
                                                                                      ColumnDefinitions="*,Auto"
                                                                                      ColumnSpacing="6">
                                                                                    <TextBlock Text="{Binding DisplayName}"
                                                                                               Classes="characterStatePreviewTitle"
                                                                                               TextTrimming="CharacterEllipsis"/>
                                                                                    <Border Grid.Column="1"
                                                                                            Classes="characterStatePreviewBadge"
                                                                                            Background="{Binding StatusBrush}">
                                                                                        <TextBlock Text="{Binding StatusText}"
                                                                                                   Classes="characterStatePreviewBadgeText"/>
                                                                                    </Border>
                                                                                </Grid>
                                                                                <TextBlock Grid.Row="2"
                                                                                           Text="{Binding DetailText}"
                                                                                           Classes="characterStatePreviewDetail"
                                                                                           TextWrapping="Wrap"/>
                                                                            </Grid>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border Classes="inlineSettingsInnerCard">
                                                        <StackPanel Spacing="9">
                                                            <Grid ColumnDefinitions="*,Auto"
                                                                  ColumnSpacing="8">
                                                                <StackPanel Spacing="2">
                                                                    <TextBlock Text="角色包"
                                                                               Classes="inlineSettingsCardTitle"
                                                                               FontSize="12"/>
                                                                    <TextBlock Text="{Binding InlineSettings.CharacterPackageExportCard.SummaryText}"
                                                                               Classes="inlineSettingsBody"
                                                                               TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                                <WrapPanel Grid.Column="1"
                                                                           HorizontalAlignment="Right">
                                                                    <Button Content="刷新清单"
                                                                            Classes="inlineSettingsBackButton"
                                                                            Command="{Binding InlineSettings.RefreshCharacterManifestPreviewCommand}"
                                                                            Margin="0,0,8,0"/>
                                                                    <Button Content="导出角色包"
                                                                            Classes="sendButton"
                                                                            Command="{Binding InlineSettings.ExportCharacterManifestCommand}"
                                                                            Margin="0,0,8,0"/>
                                                                    <Button Content="选择角色包"
                                                                            Classes="inlineSettingsBackButton"
                                                                            Command="{Binding InlineSettings.PickCharacterPackageManifestCommand}"
                                                                            Margin="0,0,8,0"/>
                                                                    <Button Content="导入角色包"
                                                                            Classes="sendButton"
                                                                            IsEnabled="{Binding InlineSettings.CanImportCharacterPackage}"
                                                                            Command="{Binding InlineSettings.ImportCharacterPackageCommand}"/>
                                                                </WrapPanel>
                                                            </Grid>
                                                            <Grid ColumnDefinitions="*,*"
                                                                  RowDefinitions="Auto,Auto"
                                                                  ColumnSpacing="8"
                                                                  RowSpacing="8">
                                                                <Border Classes="characterPackageFormatItem">
                                                                    <StackPanel Spacing="2">
                                                                        <TextBlock Text="主格式"
                                                                                   Classes="characterPackageMetaLabel"/>
                                                                        <TextBlock Text="{Binding InlineSettings.CharacterPackageExportCard.SchemaText}"
                                                                                   Classes="characterPackageMetaValue"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                    </StackPanel>
                                                                </Border>
                                                                <Border Grid.Column="1"
                                                                        Classes="characterPackageFormatItem">
                                                                    <StackPanel Spacing="2">
                                                                        <TextBlock Text="导出文件"
                                                                                   Classes="characterPackageMetaLabel"/>
                                                                        <TextBlock Text="{Binding InlineSettings.CharacterPackageExportCard.ExportFileName}"
                                                                                   Classes="characterPackageMetaValue"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                    </StackPanel>
                                                                </Border>
                                                                <Border Grid.Row="1"
                                                                        Grid.ColumnSpan="2"
                                                                        Classes="characterPackageFormatItem">
                                                                    <StackPanel Spacing="2">
                                                                        <TextBlock Text="兼容策略"
                                                                                   Classes="characterPackageMetaLabel"/>
                                                                        <TextBlock Text="{Binding InlineSettings.CharacterPackageExportCard.CompatibilityText}"
                                                                                   Classes="characterPackageMetaValue"
                                                                                   TextWrapping="Wrap"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </Grid>
                                                            <Border Classes="characterPackageFormatItem"
                                                                    IsVisible="{Binding InlineSettings.HasCharacterPackageImportPreview}">
                                                                <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                                                                      RowSpacing="4">
                                                                    <TextBlock Text="{Binding InlineSettings.CharacterPackageImportPreview.SummaryText}"
                                                                               Classes="characterPackageMetaValue"
                                                                               TextWrapping="Wrap"/>
                                                                    <TextBlock Grid.Row="1"
                                                                               Text="{Binding InlineSettings.CharacterPackageImportPreview.MissingStateImageText}"
                                                                               Classes="inlineSettingsBody"
                                                                               TextWrapping="Wrap"/>
                                                                    <TextBlock Grid.Row="2"
                                                                               Text="{Binding InlineSettings.CharacterPackageImportPreview.SourceText}"
                                                                               Classes="characterStatePreviewDetail"
                                                                               TextWrapping="Wrap"/>
                                                                    <TextBlock Grid.Row="3"
                                                                               Text="{Binding InlineSettings.CharacterPackageImportPreview.ImageFolderText}"
                                                                               Classes="characterStatePreviewDetail"
                                                                               TextWrapping="Wrap"/>
                                                                </Grid>
                                                            </Border>
                                                            <ItemsControl ItemsSource="{Binding InlineSettings.CharacterManifestFormatItems}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="vm:SettingsListItem">
                                                                        <Border Classes="characterPackageFormatItem"
                                                                                Width="172"
                                                                                Margin="0,0,8,8">
                                                                            <StackPanel Spacing="3">
                                                                                <TextBlock Text="{Binding Title}"
                                                                                           Classes="characterPackageMetaLabel"/>
                                                                                <TextBlock Text="{Binding Value}"
                                                                                           Classes="characterPackageMetaValue"
                                                                                           TextTrimming="CharacterEllipsis"/>
                                                                                <TextBlock Text="{Binding Description}"
                                                                                           Classes="characterStatePreviewDetail"
                                                                                           TextWrapping="Wrap"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <TextBox Text="{Binding InlineSettings.CharacterManifestPreview}"
                                                                     Classes="characterPackagePreviewTextBox"
                                                                     IsReadOnly="True"
                                                                     AcceptsReturn="True"
                                                                     TextWrapping="Wrap"
                                                                     MinHeight="96"
                                                                     MaxHeight="150"
                                                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                                                            <Grid ColumnDefinitions="*,Auto"
                                                                  ColumnSpacing="8">
                                                                <TextBlock Text="{Binding InlineSettings.CharacterManifestStatus}"
                                                                           Classes="inlineSettingsBody"
                                                                           TextWrapping="Wrap"
                                                                           VerticalAlignment="Center"/>
                                                                <Button Grid.Column="1"
                                                                        Content="导入当前资源"
                                                                        Classes="inlineSettingsBackButton"
                                                                        Command="{Binding InlineSettings.ImportCharacterAssetsCommand}"/>
                                                            </Grid>
                                                            <TextBlock Text="{Binding InlineSettings.CharacterPackageImportStatus}"
                                                                       Classes="inlineSettingsBody"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding InlineSettings.CharacterPackageExportCard.ImportHint}"
                                                                       Classes="characterStatePreviewDetail"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ItemsControl ItemsSource="{Binding InlineSettings.CharacterStateImageItems}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:CharacterStateImageItem">
                                                                <Grid ColumnDefinitions="96,*"
                                                                      ColumnSpacing="8"
                                                                      Margin="0,0,0,6">
                                                                    <TextBlock Text="{Binding DisplayName}"
                                                                               Classes="inlineSettingsBody"
                                                                               VerticalAlignment="Center"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                    <TextBox Grid.Column="1"
                                                                             Text="{Binding FileName}"
                                                                             PlaceholderText="状态图片文件名"
                                                                             MaxLength="160"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <WrapPanel>
                                                        <Button Content="桌面图片"
                                                                Classes="inlineSettingsBackButton"
                                                                Command="{Binding InlineSettings.UseDesktopCharacterImagesCommand}"
                                                                Margin="0,0,8,8"/>
                                                        <Button Content="刷新预览"
                                                                Classes="inlineSettingsBackButton"
                                                                Command="{Binding InlineSettings.RefreshCharacterPreviewCommand}"
                                                                Margin="0,0,8,8"/>
                                                        <Button Content="扫描匹配"
                                                                Classes="inlineSettingsBackButton"
                                                                Command="{Binding InlineSettings.ScanCharacterAssetSuggestionsCommand}"
                                                                Margin="0,0,8,8"/>
                                                        <Button Content="应用匹配"
                                                                Classes="inlineSettingsBackButton"
                                                                Command="{Binding InlineSettings.ApplyCharacterAssetSuggestionsCommand}"
                                                                Margin="0,0,8,8"/>
                                                        <Button Content="导入资源"
                                                                Classes="inlineSettingsBackButton"
                                                                Command="{Binding InlineSettings.ImportCharacterAssetsCommand}"
                                                                Margin="0,0,8,8"/>
                                                        <Button Content="保存"
                                                                Classes="sendButton"
                                                                Command="{Binding InlineSettings.SaveCharacterCommand}"
                                                                Margin="0,0,8,8"/>
                                                        <Button Content="恢复默认"
                                                                Classes="inlineSettingsBackButton"
                                                                Command="{Binding InlineSettings.ResetCharacterCommand}"
                                                                Margin="0,0,8,8"/>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Spacing="12"
                                                IsVisible="{Binding InlineSettings.IsDataSectionSelected}">
                                        <Border Classes="inlineSettingsCard">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="日志/数据"
                                                           Classes="inlineSettingsCardTitle"/>
                                                <TextBlock Text="{Binding InlineSettings.DataStorageSummary}"
                                                           Classes="inlineSettingsBody"
                                                           TextWrapping="Wrap"/>
                                                <ItemsControl ItemsSource="{Binding InlineSettings.DataDirectoryItems}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:DataDirectoryItem">
                                                            <Border Classes="dataDirectoryRow"
                                                                    Margin="0,0,0,8">
                                                                <Grid ColumnDefinitions="*,Auto"
                                                                      RowDefinitions="Auto,Auto,Auto"
                                                                      ColumnSpacing="10"
                                                                      RowSpacing="4">
                                                                    <TextBlock Text="{Binding Title}"
                                                                               Classes="inlineSettingsCardTitle"
                                                                               FontSize="12"/>
                                                                    <Button Grid.Column="1"
                                                                            Content="打开"
                                                                            Classes="inlineSettingsBackButton"
                                                                            Command="{Binding OpenCommand}"
                                                                            Padding="10,5"/>
                                                                    <TextBlock Grid.Row="1"
                                                                               Grid.ColumnSpan="2"
                                                                               Text="{Binding Path}"
                                                                               Classes="inlineSettingsBody"
                                                                               TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock Grid.Row="2"
                                                                               Text="{Binding Description}"
                                                                               Classes="inlineSettingsBody"
                                                                               TextWrapping="Wrap"/>
                                                                    <TextBlock Grid.Row="2"
                                                                               Grid.Column="1"
                                                                               Text="{Binding Status}"
                                                                               Classes="inlineSettingsBody"
                                                                               HorizontalAlignment="Right"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <TextBlock Text="{Binding InlineSettings.DataSettingsStatus}"
                                                           Classes="inlineSettingsBody"
                                                           TextWrapping="Wrap"/>
                                                <WrapPanel>
                                                    <Button Content="刷新目录"
                                                            Classes="inlineSettingsBackButton"
                                                            Command="{Binding InlineSettings.RefreshDataDirectoriesCommand}"
                                                            Margin="0,0,8,8"/>
                                                    <Button Content="打开数据根目录"
                                                            Classes="inlineSettingsBackButton"
                                                            Command="{Binding InlineSettings.OpenDataRootDirectoryCommand}"
                                                            Margin="0,0,8,8"/>
                                                    <Button Content="清理本地缓存"
                                                            Classes="inlineSettingsBackButton"
                                                            Command="{Binding InlineSettings.ClearDataCacheCommand}"
                                                            Margin="0,0,8,8"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <Border Classes="inlineSettingsCard">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="当前状态"
                                                       Classes="inlineSettingsCardTitle"/>
                                            <TextBlock Text="{Binding InlineSettingsStatus}"
                                                       Classes="inlineSettingsBody"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                            <Border Classes="inlineSettingsBusyOverlay"
                                    IsVisible="{Binding InlineSettings.IsBusy}">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="8">
                                    <ProgressBar Classes="compactProgress"
                                                 IsIndeterminate="True"
                                                 Width="160"/>
                                    <TextBlock Text="正在处理设置操作..."
                                               Classes="inlineSettingsBody"
                                               TextAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
